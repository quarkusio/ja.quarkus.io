# Example environment configuration file
# Copy this file to .env and fill in your values
# (.env is git-ignored)

# Gemini API key for translation
TSUJI_TRANSLATOR_GEMINI_KEY=your-api-key-here

# Optional: Custom API endpoint (e.g., company metering proxy)
# Uncomment if you need to use a custom endpoint instead of the standard public Gemini API
# QUARKUS_LANGCHAIN4J_AI_GEMINI_BASE_URL=https://your-company-proxy.example.com/api/gemini
