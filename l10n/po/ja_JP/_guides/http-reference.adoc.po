#. mt: gemini
#: _guides/http-reference.adoc
msgid "`X-Forwarded-Host`"
msgstr "`X-Forwarded-Host`"

#. type: Plain text
#. mt: gemini
#: _guides/http-reference.adoc
msgid "`X-Forwarded-Port`"
msgstr "`X-Forwarded-Port`"

#. type: Plain text
#. mt: gemini
#: _guides/http-reference.adoc
msgid "`X-Forwarded-Ssl`"
msgstr "`X-Forwarded-Ssl`"

