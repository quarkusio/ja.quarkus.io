#: _guides/extension-writing-dev-service.adoc
msgid "In your xref:writing-extensions.adoc#project-setup[deployment] module:"
msgstr ""

#. type: Block title
#: _guides/extension-writing-dev-service.adoc
msgid "pom.xml"
msgstr "pom.xml"

#. type: Block title
#: _guides/extension-writing-dev-service.adoc
msgid "build.gradle"
msgstr "build.gradle"

#. type: Plain text
