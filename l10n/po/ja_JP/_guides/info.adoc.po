#. type: YAML Front Matter: title
#: _guides/info.adoc
msgid "Application Info Endpoint"
msgstr ""

#. type: Plain text
#: _guides/info.adoc
msgid "The `quarkus-info` extension exposes an HTTP endpoint at `/q/info` that returns information about the application: build metadata, git commit, Java version, and operating system."
msgstr ""

#. type: Title =
#: _guides/info.adoc
msgid "Adding the extension"
msgstr ""

#. type: Plain text
#: _guides/info.adoc
