#. This guide is maintained in the main Quarkus repository
#. and pull requests should be submitted there:
#. https://github.com/quarkusio/quarkus/tree/main/docs/src/main/asciidoc
#. type: Title =
#: upstream/_guides/hibernate-panache-next.adoc:6
#, no-wrap
msgid "Simplified Hibernate with Panache Next"
msgstr "Panache Next によってシンプルになった Hibernate"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:17
msgid "Hibernate with Panache Next is the perfect solution if you want to get started using Hibernate in Quarkus."
msgstr "Quarkus で Hibernate の使用を開始したい場合、Panache Next を使用した Hibernate は完璧なソリューションです。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:24
msgid "This extension is currently experimental, so its API may change, in particular names of classes or packages may change, even the module name. We are in the process of making it a public preview in order to obtain public feedback, so please report feedback either on link:https://quarkusio.zulipchat.com/#narrow/channel/187038-dev/topic/WG.20-.20Panache.2ENext/with/562916276[Zulip] or via link:https://github.com/orgs/quarkusio/projects/50/views/1[GitHub issues]."
msgstr "このエクステンションは現在実験段階にあるため、API が変更される可能性があり、特にクラス名、パッケージ名、さらにはモジュール名も変更される場合があります。現在、公開プレビューにして皆様からのフィードバックを募っているところですので、link:https://quarkusio.zulipchat.com/#narrow/channel/187038-dev/topic/WG.20-.20Panache.2ENext/with/562916276[Zulip] または link:https://github.com/orgs/quarkusio/projects/50/views/1[GitHub Issues] からフィードバックをお寄せください。"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:25
#, no-wrap
msgid "Walk-through"
msgstr "ウォークスルー"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:28
msgid "Let's take a progressive approach to learning how to use Hibernate with Panache, and start with a simple entity."
msgstr "Hibernate with Panache の使用方法を学ぶために、段階的なアプローチを取り、シンプルなエンティティーから始めましょう。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:33
msgid "This guide is not going to go into the specifics of using either xref:hibernate-orm.adoc[Hibernate], or its underlying link:{jakarta-persistence-spec-url}[Jakarta Persistence specification], because both already have great documentation that you can and should use for more in-depth knowledge."
msgstr "このガイドでは、xref:hibernate-orm.adoc[Hibernate] やその基盤となる link:{jakarta-persistence-spec-url}[Jakarta Persistence 仕様] の具体的な使用方法については深く触れません。なぜなら、どちらも既に詳細な知識を得るために利用できる優れたドキュメントが用意されているからです。"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:34
#, no-wrap
msgid "Importing the extension, and configuration"
msgstr "エクステンションのインポートと設定"

#. type: Block title
#: upstream/_guides/hibernate-panache-next.adoc:37
#: upstream/_guides/hibernate-panache-next.adoc:64
#: upstream/_guides/hibernate-panache-next.adoc:618
#: upstream/_guides/hibernate-panache-next.adoc:1092
#, no-wrap
msgid "pom.xml"
msgstr "pom.xml"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:49
#, no-wrap
msgid ""
"<!-- Import the Hibernate with Panache extension -->\n"
"<dependency>\n"
"    <groupId>io.quarkus</groupId>\n"
"    <artifactId>quarkus-hibernate-panache-next</artifactId>\n"
"</dependency>\n"
"<!-- Pick your database driver -->\n"
"<dependency>\n"
"    <groupId>io.quarkus</groupId>\n"
"    <artifactId>quarkus-jdbc-postgresql</artifactId>\n"
"</dependency>\n"
msgstr ""
"<!-- Import the Hibernate with Panache extension -->\n"
"<dependency>\n"
"    <groupId>io.quarkus</groupId>\n"
"    <artifactId>quarkus-hibernate-panache-next</artifactId>\n"
"</dependency>\n"
"<!-- Pick your database driver -->\n"
"<dependency>\n"
"    <groupId>io.quarkus</groupId>\n"
"    <artifactId>quarkus-jdbc-postgresql</artifactId>\n"
"</dependency>\n"

#. type: Block title
#: upstream/_guides/hibernate-panache-next.adoc:52
#: upstream/_guides/hibernate-panache-next.adoc:87
#: upstream/_guides/hibernate-panache-next.adoc:638
#: upstream/_guides/hibernate-panache-next.adoc:1101
#, no-wrap
msgid "build.gradle"
msgstr "build.gradle"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:56
#, no-wrap
msgid ""
"// Import the Hibernate with Panache extension\n"
"implementation(\"io.quarkus:quarkus-hibernate-panache-next\")\n"
msgstr ""
"// Import the Hibernate with Panache extension\n"
"implementation(\"io.quarkus:quarkus-hibernate-panache-next\")\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:59
#, no-wrap
msgid ""
"// Pick your database driver\n"
"implementation(\"io.quarkus:quarkus-jdbc-postgresql\")\n"
msgstr ""
"// Pick your database driver\n"
"implementation(\"io.quarkus:quarkus-jdbc-postgresql\")\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:62
msgid "You also have to configure the Hibernate processor, which is required:"
msgstr "また、必須である Hibernate プロセッサーを設定する必要があります。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:84
#, no-wrap
msgid ""
"<plugin>\n"
"    <artifactId>maven-compiler-plugin</artifactId>\n"
"    <configuration>\n"
"        <!-- This setting is required for the annotation processor dependencies to be managed by Quarkus.\n"
"             More information is available in Maven compiler plugin documentation:\n"
"             https://maven.apache.org/plugins/maven-compiler-plugin/compile-mojo.html#annotationProcessorPathsUseDepMgmt -->\n"
"        <annotationProcessorPathsUseDepMgmt>true</annotationProcessorPathsUseDepMgmt>\n"
"        <annotationProcessorPaths>\n"
"            <path>\n"
"                <groupId>org.hibernate.orm</groupId>\n"
"                <artifactId>hibernate-processor</artifactId>\n"
"                <!-- Note, no artifact version is required, it's managed by Quarkus.  -->\n"
"            </path>\n"
"            <!-- other processors that may be required by your app -->\n"
"        </annotationProcessorPaths>\n"
"        <!-- Other compiler plugin configuration options -->\n"
"    </configuration>\n"
"</plugin>\n"
msgstr ""
"<plugin>\n"
"    <artifactId>maven-compiler-plugin</artifactId>\n"
"    <configuration>\n"
"        <!-- This setting is required for the annotation processor dependencies to be managed by Quarkus.\n"
"             More information is available in Maven compiler plugin documentation:\n"
"             https://maven.apache.org/plugins/maven-compiler-plugin/compile-mojo.html#annotationProcessorPathsUseDepMgmt -->\n"
"        <annotationProcessorPathsUseDepMgmt>true</annotationProcessorPathsUseDepMgmt>\n"
"        <annotationProcessorPaths>\n"
"            <path>\n"
"                <groupId>org.hibernate.orm</groupId>\n"
"                <artifactId>hibernate-processor</artifactId>\n"
"                <!-- Note, no artifact version is required, it's managed by Quarkus.  -->\n"
"            </path>\n"
"            <!-- other processors that may be required by your app -->\n"
"        </annotationProcessorPaths>\n"
"        <!-- Other compiler plugin configuration options -->\n"
"    </configuration>\n"
"</plugin>\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:93
#, no-wrap
msgid ""
"// Enforce the version management of your annotation processor dependencies,\n"
"// so that there's no need to define an explicit version of the hibernate-processor\n"
"annotationProcessor enforcedPlatform(\"${quarkusPlatformGroupId}:${quarkusPlatformArtifactId}:${quarkusPlatformVersion}\")\n"
"annotationProcessor 'org.hibernate.orm:hibernate-processor'\n"
msgstr ""
"// Enforce the version management of your annotation processor dependencies,\n"
"// so that there's no need to define an explicit version of the hibernate-processor\n"
"annotationProcessor enforcedPlatform(\"${quarkusPlatformGroupId}:${quarkusPlatformArtifactId}:${quarkusPlatformVersion}\")\n"
"annotationProcessor 'org.hibernate.orm:hibernate-processor'\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:96
msgid "You can use any of the xref:hibernate-orm.adoc#setting-up-and-configuring-hibernate-orm[supported JDBC drivers]."
msgstr "xref:hibernate-orm.adoc#setting-up-and-configuring-hibernate-orm[サポートされている JDBC ドライバー] のいずれかを使用できます。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:99
msgid "Make sure you configure your datasource in your `application.properties` (although you don't have to in DEV mode: if you don't, a dev service will be provided for you):"
msgstr "`application.properties` でデータソースを設定してください (ただし、開発モード の場合は必須ではありません。設定しない場合は dev service が提供されます):"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:105
#, no-wrap
msgid ""
"%prod.quarkus.datasource.username = hibernate\n"
"%prod.quarkus.datasource.password = hibernate\n"
"%prod.quarkus.datasource.jdbc.url = jdbc:postgresql://localhost:5432/hibernate_db\n"
msgstr ""
"%prod.quarkus.datasource.username = hibernate\n"
"%prod.quarkus.datasource.password = hibernate\n"
"%prod.quarkus.datasource.jdbc.url = jdbc:postgresql://localhost:5432/hibernate_db\n"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:107
#, no-wrap
msgid "Our first entity"
msgstr "最初のエンティティー"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:111
msgid "What this guide will focus on is the basics of how to use Hibernate with Panache, so let's start with how to create an entity:"
msgstr "このガイドでは、Panache で Hibernate を使用するための基本に焦点を当てます。まずは、エンティティーの作成方法から始めましょう。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:116
#, no-wrap
msgid ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import jakarta.persistence.Entity;\n"
msgstr ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import jakarta.persistence.Entity;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:118
#: upstream/_guides/hibernate-panache-next.adoc:854
#, no-wrap
msgid "import java.time.LocalDate;\n"
msgstr "import java.time.LocalDate;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:124
#: upstream/_guides/hibernate-panache-next.adoc:196
#: upstream/_guides/hibernate-panache-next.adoc:958
#, no-wrap
msgid ""
"@Entity\n"
"public class Cat extends PanacheEntity {\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"
msgstr ""
"@Entity\n"
"public class Cat extends PanacheEntity {\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:129
#, no-wrap
msgid ""
"    public enum Breed {\n"
"        CUTE, HAIRLESS;\n"
"    }\n"
"}\n"
msgstr ""
"    public enum Breed {\n"
"        CUTE, HAIRLESS;\n"
"    }\n"
"}\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:132
msgid "In order to map a Java class to a Database table, just:"
msgstr "Java クラスをデータベーステーブルにマッピングするには、次の手順を実行します。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:134
msgid "Write a class"
msgstr "クラスを作成する"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:135
msgid "Annotate it with link:{jakarta-persistence-javadocs-url}/jakarta/persistence/entity[`@Entity`]"
msgstr "link:{jakarta-persistence-javadocs-url}/jakarta/persistence/entity[`@Entity`] アノテーションを付与します。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:136
msgid "Make it extend `PanacheEntity`"
msgstr "`PanacheEntity` を継承させます。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:137
msgid "Make its fields `public`"
msgstr "そのフィールドを `public` にします。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:141
msgid "And that's it, now you can start creating instances of your entity, persist it to your database, after which point all changes to its fields will be automatically sent to the database (no need for any explicit `update` instruction), and even remove it from the database:"
msgstr "これで完了です。エンティティーのインスタンスを作成し、データベースに永続化できます。その後、フィールドへの変更はすべて自動的にデータベースに送信され (明示的な `update` 命令は不要)、データベースから削除することもできます。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:145
#, no-wrap
msgid "import jakarta.transaction.Transactional;\n"
msgstr "import jakarta.transaction.Transactional;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:148
#: upstream/_guides/hibernate-panache-next.adoc:190
#: upstream/_guides/hibernate-panache-next.adoc:278
#: upstream/_guides/hibernate-panache-next.adoc:451
#: upstream/_guides/hibernate-panache-next.adoc:527
#: upstream/_guides/hibernate-panache-next.adoc:565
#: upstream/_guides/hibernate-panache-next.adoc:678
#: upstream/_guides/hibernate-panache-next.adoc:766
#: upstream/_guides/hibernate-panache-next.adoc:804
#: upstream/_guides/hibernate-panache-next.adoc:952
#: upstream/_guides/hibernate-panache-next.adoc:1128
#, no-wrap
msgid ""
"import java.time.LocalDate;\n"
"import java.util.List;\n"
msgstr ""
"import java.time.LocalDate;\n"
"import java.util.List;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:150
#: upstream/_guides/hibernate-panache-next.adoc:280
#: upstream/_guides/hibernate-panache-next.adoc:354
#: upstream/_guides/hibernate-panache-next.adoc:398
#: upstream/_guides/hibernate-panache-next.adoc:567
#: upstream/_guides/hibernate-panache-next.adoc:720
#: upstream/_guides/hibernate-panache-next.adoc:806
#: upstream/_guides/hibernate-panache-next.adoc:856
#: upstream/_guides/hibernate-panache-next.adoc:985
#, no-wrap
msgid "public class Code {\n"
msgstr "public class Code {\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:157
#, no-wrap
msgid ""
"    @Transactional <1>\n"
"    public void method() {\n"
"        Cat cat = new Cat();\n"
"        cat.name = \"Lucky\";\n"
"        cat.birth = LocalDate.of(2015, 01, 12);\n"
"        cat.breed = Cat.Breed.CUTE;\n"
msgstr ""
"    @Transactional <1>\n"
"    public void method() {\n"
"        Cat cat = new Cat();\n"
"        cat.name = \"Lucky\";\n"
"        cat.birth = LocalDate.of(2015, 01, 12);\n"
"        cat.breed = Cat.Breed.CUTE;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:160
#: upstream/_guides/hibernate-panache-next.adoc:293
#: upstream/_guides/hibernate-panache-next.adoc:866
#, no-wrap
msgid ""
"        // Persist the cat\n"
"        cat.persist();\n"
msgstr ""
"        // Persist the cat\n"
"        cat.persist();\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:163
#: upstream/_guides/hibernate-panache-next.adoc:296
#, no-wrap
msgid ""
"        // Make a change, no need to update it\n"
"        cat.name = \"Luckynou\";\n"
msgstr ""
"        // Make a change, no need to update it\n"
"        cat.name = \"Luckynou\";\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:168
#, no-wrap
msgid ""
"        // Delete our cat\n"
"        cat.delete();\n"
"    }\n"
"}\n"
msgstr ""
"        // Delete our cat\n"
"        cat.delete();\n"
"    }\n"
"}\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:170
msgid "This is required on any method which interacts with the database, in order to run the operations in a transaction."
msgstr "これは、データベースと対話するあらゆるメソッドで、トランザクション内の操作を実行するために必要です。"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:171
#, no-wrap
msgid "Our first repository"
msgstr "最初のリポジトリー"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:175
msgid "Now that we know how to create, update and delete our entities, let's see how we can query our database to find them, or even run delete queries."
msgstr "エンティティーの作成、更新、削除の方法がわかったので、データベースをクエリーしてエンティティーを検索したり、削除クエリーを実行したりする方法を見ていきましょう。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:179
msgid "Because query operations do not belong on instances of our entities, we will place these operations on another type called a `Repository`, and because those queries are intimately tied with the entities they operate on, we recommend placing them on an interface nested in the entity:"
msgstr "クエリー操作はエンティティーのインスタンスに属するものではないため、これらの操作は `Repository` と呼ばれる別の型に配置します。これらのクエリーは操作対象のエンティティーと密接に結びついているため、エンティティー内にネストされたインターフェースに配置することをお勧めします。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:187
#, no-wrap
msgid ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import io.quarkus.hibernate.panache.PanacheRepository;\n"
"import jakarta.persistence.Entity;\n"
"import org.hibernate.annotations.processing.Find;\n"
"import org.hibernate.annotations.processing.HQL;\n"
msgstr ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import io.quarkus.hibernate.panache.PanacheRepository;\n"
"import jakarta.persistence.Entity;\n"
"import org.hibernate.annotations.processing.Find;\n"
"import org.hibernate.annotations.processing.HQL;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:200
#: upstream/_guides/hibernate-panache-next.adoc:463
#: upstream/_guides/hibernate-panache-next.adoc:537
#: upstream/_guides/hibernate-panache-next.adoc:688
#: upstream/_guides/hibernate-panache-next.adoc:776
#: upstream/_guides/hibernate-panache-next.adoc:962
#: upstream/_guides/hibernate-panache-next.adoc:1141
#, no-wrap
msgid ""
"    public enum Breed {\n"
"        CUTE, HAIRLESS;\n"
"    }\n"
msgstr ""
"    public enum Breed {\n"
"        CUTE, HAIRLESS;\n"
"    }\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:204
#, no-wrap
msgid ""
"    public interface Repo extends PanacheRepository<Cat> {\n"
"        @Find\n"
"        Cat findByName(String name);\n"
msgstr ""
"    public interface Repo extends PanacheRepository<Cat> {\n"
"        @Find\n"
"        Cat findByName(String name);\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:207
#: upstream/_guides/hibernate-panache-next.adoc:544
#, no-wrap
msgid ""
"        @HQL(\"where breed = CUTE\")\n"
"        List<Cat> findCute();\n"
msgstr ""
"        @HQL(\"where breed = CUTE\")\n"
"        List<Cat> findCute();\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:210
#: upstream/_guides/hibernate-panache-next.adoc:473
#: upstream/_guides/hibernate-panache-next.adoc:547
#, no-wrap
msgid ""
"        @HQL(\"delete from Cat where name = :name\")\n"
"        long deleteByName(String name);\n"
msgstr ""
"        @HQL(\"delete from Cat where name = :name\")\n"
"        long deleteByName(String name);\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:215
#: upstream/_guides/hibernate-panache-next.adoc:478
#: upstream/_guides/hibernate-panache-next.adoc:552
#, no-wrap
msgid ""
"        @HQL(\"delete from Cat where breed = HAIRLESS\")\n"
"        long deleteHairless();\n"
"    }\n"
"}\n"
msgstr ""
"        @HQL(\"delete from Cat where breed = HAIRLESS\")\n"
"        long deleteHairless();\n"
"    }\n"
"}\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:218
msgid "A Hibernate with Panache repository is:"
msgstr "Panache リポジトリーと連携する Hibernate は次のとおりです。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:220
msgid "An interface nested in the entity (though it could be a toplevel interface if you prefer)"
msgstr "エンティティー内にネストされたインターフェース (ただし、必要であればトップレベルのインターフェースにすることもできます)"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:221
msgid "Which extends the `PanacheRepository` interface, with the entity in question as type parameter"
msgstr "`PanacheRepository` インターフェースを継承し、対象のエンティティーを型パラメーターとして指定します。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:223
msgid "And contains query methods, annotated with either `@Find` or `@HQL` or even `@SQL` (for native queries), or `default` methods with implementation of queries"
msgstr "そして、`@Find` または `@HQL`、さらには `@SQL` (ネイティブクエリーの場合) のいずれかでアノテーションが付けられたクエリーメソッド、またはクエリーの実装を持つ `default` メソッドが含まれます。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:227
msgid "You can use `@Find` methods to find single instances, or collections of entities, by using the parameters of the method to build a query. The Hibernate documentation has https://docs.jboss.org/hibernate/orm/7.1/introduction/html_single/Hibernate_Introduction.html#generated-finder-methods[all the information you need about this]."
msgstr "`@Find` メソッドを使用して、メソッドのパラメーターでクエリーを構築することにより、単一のインスタンスまたはエンティティーのコレクションを見つけることができます。Hibernate のドキュメントには https://docs.jboss.org/hibernate/orm/7.1/introduction/html_single/Hibernate_Introduction.html#generated-finder-methods[このことに関する必要な情報がすべて] 記載されています。"

#. type: Block title
#: upstream/_guides/hibernate-panache-next.adoc:228
#: upstream/_guides/hibernate-panache-next.adoc:247
#, no-wrap
msgid "A few common examples"
msgstr "いくつかの一般的な例"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:233
#, no-wrap
msgid ""
"@Find\n"
"public List<Cat> findAllCats(); <1>\n"
msgstr ""
"@Find\n"
"public List<Cat> findAllCats(); <1>\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:236
#, no-wrap
msgid ""
"@Find\n"
"public long countAllCats(); <2>\n"
msgstr ""
"@Find\n"
"public long countAllCats(); <2>\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:239
#, no-wrap
msgid ""
"@Find\n"
"public Cat findCatByNameAndBreed(String name, Breed breed); <3>\n"
msgstr ""
"@Find\n"
"public Cat findCatByNameAndBreed(String name, Breed breed); <3>\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:241
msgid "Finder methods may return collections of entities"
msgstr "ファインダーメソッドはエンティティーのコレクションを返す場合があります"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:242
msgid "Or generate `COUNT` queries"
msgstr "または `COUNT` クエリーを生成します"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:243
msgid "Or single entities, and any number of parameters which must all match the queried entities."
msgstr "または単一のエンティティー、およびクエリーされたエンティティーとすべて一致する必要がある任意の数のパラメーターを使用します。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:246
msgid "Alternately, you can use `@HQL` or `@SQL` queries, which support HQL and SQL queries. Once again the Hibernate documentation has https://docs.jboss.org/hibernate/orm/7.1/introduction/html_single/Hibernate_Introduction.html#generated-query-methods[all the information you need]."
msgstr "あるいは、HQL と SQL クエリーをサポートする `@HQL` または `@SQL` クエリーを使用することもできます。これについても、Hibernate のドキュメントに https://docs.jboss.org/hibernate/orm/7.1/introduction/html_single/Hibernate_Introduction.html#generated-query-methods[必要な情報がすべて] 記載されています。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:252
#, no-wrap
msgid ""
"@HQL(\"from Cat\")\n"
"public List<Cat> findAllCats(); <1>\n"
msgstr ""
"@HQL(\"from Cat\")\n"
"public List<Cat> findAllCats(); <1>\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:255
#, no-wrap
msgid ""
"@HQL(\"select min(birth) from Cat\")\n"
"public LocalDate oldestCat(); <2>\n"
msgstr ""
"@HQL(\"select min(birth) from Cat\")\n"
"public LocalDate oldestCat(); <2>\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:258
#, no-wrap
msgid ""
"@HQL(\"where name = :name and breed = :breed\")\n"
"public Cat findCatByNameAndBreed(String name, Breed breed); <3>\n"
msgstr ""
"@HQL(\"where name = :name and breed = :breed\")\n"
"public Cat findCatByNameAndBreed(String name, Breed breed); <3>\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:260
msgid "Query methods may return collections of entities"
msgstr "クエリーメソッドはエンティティーのコレクションを返す場合があります"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:261
msgid "Or projections of a single column, even multiple columns with `Object[]` and `List<Object[]>` types"
msgstr "または単一列のプロジェクション、さらに `Object[]` および `List<Object[]>` 型を使用した複数列のプロジェクションも可能です。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:262
msgid "Queries can of course refer to method parameters."
msgstr "クエリーはもちろんメソッドパラメーターを参照できます。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:266
msgid "The beauty of generated finder and query methods is that they are type-checked at build time: they will be validated and guarantee that you did not make any typo in the entity names, their fields, the HQL/SQL syntax, or the name of their parameters."
msgstr "生成されたファインダーメソッドとクエリーメソッドの利点は、ビルド時に型チェックされることです。これにより、エンティティー名、そのフィールド、HQL/SQL 構文、またはパラメーター名にタイプミスがないことが検証され、保証されます。"

#. type: Title ===
#: upstream/_guides/hibernate-panache-next.adoc:267
#, no-wrap
msgid "Using the repository"
msgstr "リポジトリーの使用"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:270
msgid "Using the repository can be done by simply injecting it where you intend to use it:"
msgstr "リポジトリーを使用するには、使用する場所に単純にインジェクトするだけです。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:275
#, no-wrap
msgid ""
"import jakarta.inject.Inject;\n"
"import jakarta.transaction.Transactional;\n"
msgstr ""
"import jakarta.inject.Inject;\n"
"import jakarta.transaction.Transactional;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:283
#: upstream/_guides/hibernate-panache-next.adoc:357
#: upstream/_guides/hibernate-panache-next.adoc:401
#: upstream/_guides/hibernate-panache-next.adoc:570
#: upstream/_guides/hibernate-panache-next.adoc:723
#: upstream/_guides/hibernate-panache-next.adoc:809
#: upstream/_guides/hibernate-panache-next.adoc:988
#, no-wrap
msgid ""
"    @Inject\n"
"    Cat.Repo repo;\n"
msgstr ""
"    @Inject\n"
"    Cat.Repo repo;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:290
#: upstream/_guides/hibernate-panache-next.adoc:577
#, no-wrap
msgid ""
"    @Transactional\n"
"    public void method() {\n"
"        Cat cat = new Cat();\n"
"        cat.name = \"Lucky\";\n"
"        cat.birth = LocalDate.of(2015, 01, 12);\n"
"        cat.breed = Cat.Breed.CUTE;\n"
msgstr ""
"    @Transactional\n"
"    public void method() {\n"
"        Cat cat = new Cat();\n"
"        cat.name = \"Lucky\";\n"
"        cat.birth = LocalDate.of(2015, 01, 12);\n"
"        cat.breed = Cat.Breed.CUTE;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:299
#: upstream/_guides/hibernate-panache-next.adoc:587
#, no-wrap
msgid ""
"        // Find our cat\n"
"        cat = repo.findByName(\"Luckynou\");\n"
msgstr ""
"        // Find our cat\n"
"        cat = repo.findByName(\"Luckynou\");\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:302
#: upstream/_guides/hibernate-panache-next.adoc:590
#, no-wrap
msgid ""
"        // Find cute cats\n"
"        List<Cat> cuteCats = repo.findCute();\n"
msgstr ""
"        // Find cute cats\n"
"        List<Cat> cuteCats = repo.findCute();\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:305
#: upstream/_guides/hibernate-panache-next.adoc:593
#, no-wrap
msgid ""
"        // Delete our cat\n"
"        cat.delete();\n"
msgstr ""
"        // Delete our cat\n"
"        cat.delete();\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:311
#: upstream/_guides/hibernate-panache-next.adoc:599
#, no-wrap
msgid ""
"        // Delete queries\n"
"        repo.deleteByName(\"Lucky\");\n"
"        repo.deleteHairless();\n"
"    }\n"
"}\n"
msgstr ""
"        // Delete queries\n"
"        repo.deleteByName(\"Lucky\");\n"
"        repo.deleteHairless();\n"
"    }\n"
"}\n"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:318
msgid "Now, as an added benefit, you can also access the repository using a handy shortcut generated static method on the https://docs.jboss.org/hibernate/orm/7.1/introduction/html_single/Hibernate_Introduction.html#static-metamodel[generated Metamodel] of your entity, which is super useful for discovery of operations (just type `Cat_.repo().` and see all your methods)  and to avoid making a detour outside of your method to add an injected field, such as in this startup code that will delete all your cats (don't do this in production!!):"
msgstr "さらに、エンティティーの https://docs.jboss.org/hibernate/orm/7.1/introduction/html_single/Hibernate_Introduction.html#static-metamodel[生成されたメタモデル] 上の便利なショートカット生成静的メソッドを使用してリポジトリーにアクセスすることもできます。これは、操作の発見 (単に `Cat_.repo().` と入力するだけで、すべてのメソッドが表示されます) に非常に役立ち、メソッドの外側に回り道してインジェクトされたフィールドを追加するのを避けるためにも便利です。たとえば、このスタートアップコードはすべての猫を削除します (本番環境では絶対に行わないでください!!):"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:323
#: upstream/_guides/hibernate-panache-next.adoc:1060
#, no-wrap
msgid ""
"import io.quarkus.runtime.Startup;\n"
"import jakarta.transaction.Transactional;\n"
msgstr ""
"import io.quarkus.runtime.Startup;\n"
"import jakarta.transaction.Transactional;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:331
#: upstream/_guides/hibernate-panache-next.adoc:1068
#, no-wrap
msgid ""
"public class OnStart {\n"
"    @Startup\n"
"    @Transactional\n"
"    public void startupMethod() {\n"
"        Cat_.repo().deleteAll();\n"
"    }\n"
"}\n"
msgstr ""
"public class OnStart {\n"
"    @Startup\n"
"    @Transactional\n"
"    public void startupMethod() {\n"
"        Cat_.repo().deleteAll();\n"
"    }\n"
"}\n"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:336
msgid "All the repositories you define as nested interfaces of your entity will be available under their generated metamodel class under accessor methods of the same name as the repository. This is strictly equivalent to injecting the repository type, and in fact uses CDI under the hood to look up the repository."
msgstr "エンティティーのネストされたインターフェースとして定義するすべてのリポジトリーは、生成されたメタモデルクラスの下にある、リポジトリーと同じ名前のアクセサーメソッドの下で利用可能になります。これはリポジトリー型のインジェクションと厳密に同等であり、実際には内部で CDI を使用してリポジトリーを検索します。"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:337
#, no-wrap
msgid "The `PanacheRepository` super type"
msgstr "`PanacheRepository` スーパークラス"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:341
msgid "Just like in previous versions of Hibernate ORM and Hibernate Reactive with Panache, the `PanacheRepository` type comes packed with most of the operations you need to work on your entity, such as, out of the box:"
msgstr "以前のバージョンの Hibernate ORM や Hibernate Reactive with Panache と同様に、`PanacheRepository` 型には、エンティティーを操作するために必要なほとんどの操作がすぐに利用できる形で含まれています。たとえば、次のようになります。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:348
#: upstream/_guides/hibernate-panache-next.adoc:392
#, no-wrap
msgid ""
"import io.quarkus.hibernate.panache.blocking.PanacheBlockingQuery;\n"
"import jakarta.inject.Inject;\n"
"import jakarta.transaction.Transactional;\n"
"import org.hibernate.Session;\n"
msgstr ""
"import io.quarkus.hibernate.panache.blocking.PanacheBlockingQuery;\n"
"import jakarta.inject.Inject;\n"
"import jakarta.transaction.Transactional;\n"
"import org.hibernate.Session;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:352
#: upstream/_guides/hibernate-panache-next.adoc:396
#: upstream/_guides/hibernate-panache-next.adoc:718
#, no-wrap
msgid ""
"import java.time.LocalDate;\n"
"import java.util.List;\n"
"import java.util.Optional;\n"
msgstr ""
"import java.time.LocalDate;\n"
"import java.util.List;\n"
"import java.util.Optional;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:379
#, no-wrap
msgid ""
"    @Transactional\n"
"    public void repositoryOperations(Cat cat) {\n"
"        // entity operations\n"
"        repo.persist(cat);\n"
"        repo.delete(cat);\n"
"        boolean isPersistent = repo.isPersistent(cat);\n"
"        // operations on all entities\n"
"        long count = repo.count();\n"
"        long deleted = repo.deleteAll();\n"
"        List<Cat> allCats = repo.listAll();\n"
"        repo.streamAll().forEach(kitty -> kitty.name = kitty.name.toUpperCase());\n"
"        PanacheBlockingQuery<Cat> catQuery = repo.findAll();\n"
"        // operations on the Hibernate session\n"
"        repo.flush();\n"
"        Session session = repo.getSession();\n"
"        // ID-related operations\n"
"        boolean wasDeleted = repo.deleteById(cat.id);\n"
"        Cat foundCat = repo.findById(cat.id);\n"
"        Optional<Cat> optionalCat = repo.findByIdOptional(cat.id);\n"
"    }\n"
"}\n"
msgstr ""
"    @Transactional\n"
"    public void repositoryOperations(Cat cat) {\n"
"        // entity operations\n"
"        repo.persist(cat);\n"
"        repo.delete(cat);\n"
"        boolean isPersistent = repo.isPersistent(cat);\n"
"        // operations on all entities\n"
"        long count = repo.count();\n"
"        long deleted = repo.deleteAll();\n"
"        List<Cat> allCats = repo.listAll();\n"
"        repo.streamAll().forEach(kitty -> kitty.name = kitty.name.toUpperCase());\n"
"        PanacheBlockingQuery<Cat> catQuery = repo.findAll();\n"
"        // operations on the Hibernate session\n"
"        repo.flush();\n"
"        Session session = repo.getSession();\n"
"        // ID-related operations\n"
"        boolean wasDeleted = repo.deleteById(cat.id);\n"
"        Cat foundCat = repo.findById(cat.id);\n"
"        Optional<Cat> optionalCat = repo.findByIdOptional(cat.id);\n"
"    }\n"
"}\n"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:381
#, no-wrap
msgid "Non-type-safe queries"
msgstr "タイプセーフでないクエリー"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:385
msgid "With generated finder and query methods, as we've previously shown, everything is validated at build-time, but if you want to write non-type-safe queries, you can always use the provided methods of `PanacheRepository`:"
msgstr "以前に示したように、生成されたファインダーメソッドとクエリーメソッドを使用すると、すべてがビルド時に検証されますが、型安全でないクエリーを記述したい場合は、`PanacheRepository` の提供されているメソッドを常に使用できます。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:418
#, no-wrap
msgid ""
"    @Transactional\n"
"    public void nonTypeSafeQueries() {\n"
"        // Find a cat by name\n"
"        Cat cat = repo.find(Cat_.NAME, \"Lucky\").singleResult();\n"
"        // All cute cats\n"
"        List<Cat> cuteCats = repo.list(Cat_.BREED, Cat.Breed.CUTE);\n"
"        // Cats with no known birth date\n"
"        repo.stream(Cat_.BIRTH+\" is null\").forEach(kitty -> System.err.println(kitty));\n"
"        // Get rid of non-cute cats\n"
"        long deleted = repo.delete(Cat_.BREED, Cat.Breed.HAIRLESS);\n"
"        // Count ugly cats with no name\n"
"        repo.count(\"breed = ?1 and name is null\", Cat.Breed.HAIRLESS);\n"
"        // Make every cat cute\n"
"        repo.update(\"breed = CUTE\");\n"
"    }\n"
"}\n"
msgstr ""
"    @Transactional\n"
"    public void nonTypeSafeQueries() {\n"
"        // Find a cat by name\n"
"        Cat cat = repo.find(Cat_.NAME, \"Lucky\").singleResult();\n"
"        // All cute cats\n"
"        List<Cat> cuteCats = repo.list(Cat_.BREED, Cat.Breed.CUTE);\n"
"        // Cats with no known birth date\n"
"        repo.stream(Cat_.BIRTH+\" is null\").forEach(kitty -> System.err.println(kitty));\n"
"        // Get rid of non-cute cats\n"
"        long deleted = repo.delete(Cat_.BREED, Cat.Breed.HAIRLESS);\n"
"        // Count ugly cats with no name\n"
"        repo.count(\"breed = ?1 and name is null\", Cat.Breed.HAIRLESS);\n"
"        // Make every cat cute\n"
"        repo.update(\"breed = CUTE\");\n"
"    }\n"
"}\n"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:420
#, no-wrap
msgid "About entity identifiers"
msgstr "エンティティー識別子について"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:425
msgid "In the example above, we extended the `PanacheEntity` type, and did not define any database identifier, that's because `PanacheEntity` comes with a default generated database identifier, so you don't have to worry about it. It does this by extending the `WithId.AutoLong` class, which provides a generated database identifier of type `Long`."
msgstr "上記の例では、`PanacheEntity` 型を拡張しており、データベース識別子を定義していません。これは、`PanacheEntity` がデフォルトで生成されたデータベース識別子を伴って提供されるため、心配する必要がないためです。これは、`Long` 型の生成されたデータベース識別子を提供する `WithId.AutoLong` クラスを拡張することによって行われます。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:428
msgid "You can choose to extend the `WithId.AutoString` for a `String` identifier, or `WithId.AutoUUID` for a `UUID` identifier, or even extend `WithId<IdType>` to automatically get an attribute of the form:"
msgstr "`String` 識別子には `WithId.AutoString` を、`UUID` 識別子には `WithId.AutoUUID` を拡張することも、さらに `WithId<IdType>` を拡張して次の形式の属性を自動的に取得することもできます。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:434
#, no-wrap
msgid ""
"@Id\n"
"@GeneratedValue\n"
"public IdType id;\n"
msgstr ""
"@Id\n"
"@GeneratedValue\n"
"public IdType id;\n"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:439
msgid "Naturally, you can also provide your own database identifier explicitly and implement the `PanacheEntity.Managed` interface in your entity, as well as use the `PanacheRepository.Managed` interface for your repository, in order to specify you database identifier type:"
msgstr "もちろん、独自のデータベース識別子を明示的に指定し、エンティティーで `PanacheEntity.Managed` インターフェースを実装し、リポジトリーで `PanacheRepository.Managed` インターフェースを使用してデータベース識別子の型を指定することもできます。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:448
#, no-wrap
msgid ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import io.quarkus.hibernate.panache.PanacheRepository;\n"
"import jakarta.persistence.Entity;\n"
"import jakarta.persistence.Id;\n"
"import org.hibernate.annotations.processing.Find;\n"
"import org.hibernate.annotations.processing.HQL;\n"
msgstr ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import io.quarkus.hibernate.panache.PanacheRepository;\n"
"import jakarta.persistence.Entity;\n"
"import jakarta.persistence.Id;\n"
"import org.hibernate.annotations.processing.Find;\n"
"import org.hibernate.annotations.processing.HQL;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:459
#, no-wrap
msgid ""
"@Entity\n"
"public class CatWithId implements PanacheEntity.Managed {\n"
"    @Id\n"
"    public String id;\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"
msgstr ""
"@Entity\n"
"public class CatWithId implements PanacheEntity.Managed {\n"
"    @Id\n"
"    public String id;\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:467
#, no-wrap
msgid ""
"    public interface Repo extends PanacheRepository.Managed<CatWithId, String> {\n"
"        @Find\n"
"        CatWithId findByName(String name);\n"
msgstr ""
"    public interface Repo extends PanacheRepository.Managed<CatWithId, String> {\n"
"        @Find\n"
"        CatWithId findByName(String name);\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:470
#, no-wrap
msgid ""
"        @HQL(\"where breed = CUTE\")\n"
"        List<CatWithId> findCute();\n"
msgstr ""
"        @HQL(\"where breed = CUTE\")\n"
"        List<CatWithId> findCute();\n"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:482
msgid "Here is a list of entity supertypes you can use and the ID type they provide, but keep in mind you do not have to extend any of these types if you define you own ID:"
msgstr "以下に、使用できるエンティティーのスーパータイプとその提供される ID 型のリストを示しますが、独自の ID を定義する場合は、これらの型のいずれも拡張する必要がないことに留意してください。"

#. type: Table
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:503
#, no-wrap
msgid ""
"|ID type|Supertype|Shortcut type\n"
"\n"
"|`Long`\n"
"|`WithId.AutoLong`\n"
"|`PanacheEntity`\n"
"\n"
"|`UUID`\n"
"|`WithId.AutoUUID`\n"
"|\n"
"\n"
"|`String`\n"
"|`WithId.String`\n"
"|\n"
"\n"
"|`T`\n"
"|`WithId<Id>`\n"
"|\n"
"\n"
msgstr ""
"|ID 型|スーパータイプ|ショートカット型\n"
"\n"
"|`Long`\n"
"|`WithId.AutoLong`\n"
"|`PanacheEntity`\n"
"\n"
"|`UUID`\n"
"|`WithId.AutoUUID`\n"
"|\n"
"\n"
"|`String`\n"
"|`WithId.String`\n"
"|\n"
"\n"
"|`T`\n"
"|`WithId<Id>`\n"
"|\n"

#. type: Title ==
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:505
#, no-wrap
msgid "Use stateless sessions"
msgstr "ステートレスセッションの利用"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:509
msgid "Out of the box, your subtype of `PanacheEntity` will be managed by Hibernate ORM, and every change to the entity will be automatically sent to the database without requiring any explicit `update` operation."
msgstr "そのまま使用すると、`PanacheEntity` のサブタイプは Hibernate ORM によって管理され、エンティティーへの変更はすべて、明示的な `update` 操作なしで自動的にデータベースに送信されます。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:512
msgid "If on the other hand, you wish to make every `update` operation explicit, then you need to use what Hibernate ORM calls a _stateless session_."
msgstr "一方、すべての `update` 操作を明示的にしたい場合は、Hibernate ORM が _ステートレスセッション_ と呼ぶものを使用する必要があります。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:515
msgid "In this case, you need to extend `WithId.AutoLong` (or any other ID class or provide your own ID), and implement the `PanacheEntity.Stateless` and `PanacheRepository.Stateless` interfaces:"
msgstr "この場合、`WithId.AutoLong` (またはその他の ID クラス、あるいは独自の ID) を拡張し、`PanacheEntity.Stateless` および `PanacheRepository.Stateless` インターフェースを実装する必要があります。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:524
#, no-wrap
msgid ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import io.quarkus.hibernate.panache.PanacheRepository;\n"
"import io.quarkus.hibernate.panache.WithId;\n"
"import jakarta.persistence.Entity;\n"
"import org.hibernate.annotations.processing.Find;\n"
"import org.hibernate.annotations.processing.HQL;\n"
msgstr ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import io.quarkus.hibernate.panache.PanacheRepository;\n"
"import io.quarkus.hibernate.panache.WithId;\n"
"import jakarta.persistence.Entity;\n"
"import org.hibernate.annotations.processing.Find;\n"
"import org.hibernate.annotations.processing.HQL;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:533
#, no-wrap
msgid ""
"@Entity\n"
"public class Cat extends WithId.AutoLong implements PanacheEntity.Stateless {\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"
msgstr ""
"@Entity\n"
"public class Cat extends WithId.AutoLong implements PanacheEntity.Stateless {\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:541
#, no-wrap
msgid ""
"    public interface Repo extends PanacheRepository.Stateless<Cat, Long> {\n"
"        @Find\n"
"        Cat findByName(String name);\n"
msgstr ""
"    public interface Repo extends PanacheRepository.Stateless<Cat, Long> {\n"
"        @Find\n"
"        Cat findByName(String name);\n"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:556
msgid "As you can see, your entity definition is exactly the same, besides the two interfaces. But now, your entities will not be _managed_, so every update operation has to be explicit:"
msgstr "ご覧のとおり、エンティティーの定義は、2 つのインターフェースを除けばまったく同じです。しかし、これでエンティティーは _管理されなく_ なるため、すべての更新操作を明示的に行う必要があります。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:562
#, no-wrap
msgid ""
"import jakarta.inject.Inject;\n"
"import jakarta.transaction.Transactional;\n"
"import org.hibernate.StatelessSession;\n"
msgstr ""
"import jakarta.inject.Inject;\n"
"import jakarta.transaction.Transactional;\n"
"import org.hibernate.StatelessSession;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:580
#, no-wrap
msgid ""
"        // Persist the cat\n"
"        cat.insert();\n"
msgstr ""
"        // Persist the cat\n"
"        cat.insert();\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:584
#, no-wrap
msgid ""
"        // Make a change, we need to update it\n"
"        cat.name = \"Luckynou\";\n"
"        cat.update();\n"
msgstr ""
"        // Make a change, we need to update it\n"
"        cat.name = \"Luckynou\";\n"
"        cat.update();\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:602
msgid "As you can see, the only differences with a managed entity are:"
msgstr "ご覧のとおり、管理されたエンティティとの唯一の違いは次のとおりです。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:605
msgid "Any change to the entity instance fields must be explicitly pushed to the database by calling `update()` either on the entity or its repository"
msgstr "エンティティーインスタンスのフィールドへの変更はすべて、エンティティーまたはそのリポジトリーのいずれかで `update()` を呼び出すことにより、明示的にデータベースにプッシュする必要があります。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:606
msgid "You need to call `insert()` instead of `persist()` to insert the entity in the database"
msgstr "エンティティをデータベースに挿入するには、`persist()` の代わりに `insert()` を呼び出す必要があります。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:607
msgid "Your session will be of type `StatelessSession` instead of `Session`."
msgstr "セッションは `Session` 型ではなく、`StatelessSession` 型になります。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:609
msgid "But that's mostly it. Everything else stays the same, in particular for queries and how to obtain entities."
msgstr "しかし、ほとんどはこれだけです。特にクエリやエンティティの取得方法など、その他すべては同じです。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:611
#: upstream/_guides/hibernate-panache-next.adoc:839
msgid "If you're using stateless sessions, you can also use the <<Jakarta Data>> type of repositories."
msgstr "ステートレスセッションを使用している場合、<<Jakarta Data>> 型のリポジトリも使用できます。"

#. type: Title ==
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:612
#, no-wrap
msgid "Let's get reactive"
msgstr "リアクティブになろう"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:616
msgid "You want to start using your entities in a reactive application? Let's start by importing Hibernate Reactive in your `pom.xml` as well as a data source for your database:"
msgstr "リアクティブアプリケーションでエンティティーの使用を開始したいですか？まず、`pom.xml` に Hibernate Reactive とデータベースのデータソースをインポートすることから始めましょう。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:635
#, no-wrap
msgid ""
"<!-- Enable Hibernate Reactive support -->\n"
"<dependency>\n"
"    <groupId>io.quarkus</groupId>\n"
"    <artifactId>quarkus-hibernate-reactive</artifactId>\n"
"</dependency>\n"
"<!-- Pick your database reactive driver -->\n"
"<dependency>\n"
"    <groupId>io.quarkus</groupId>\n"
"    <artifactId>quarkus-reactive-pg-client</artifactId>\n"
"</dependency>\n"
"<!-- FIXME: this will not be required in the future -->\n"
"<dependency>\n"
"    <groupId>io.quarkus</groupId>\n"
"    <artifactId>quarkus-hibernate-reactive-panache-common</artifactId>\n"
"</dependency>\n"
msgstr ""
"<!-- Enable Hibernate Reactive support -->\n"
"<dependency>\n"
"    <groupId>io.quarkus</groupId>\n"
"    <artifactId>quarkus-hibernate-reactive</artifactId>\n"
"</dependency>\n"
"<!-- Pick your database reactive driver -->\n"
"<dependency>\n"
"    <groupId>io.quarkus</groupId>\n"
"    <artifactId>quarkus-reactive-pg-client</artifactId>\n"
"</dependency>\n"
"<!-- FIXME: this will not be required in the future -->\n"
"<dependency>\n"
"    <groupId>io.quarkus</groupId>\n"
"    <artifactId>quarkus-hibernate-reactive-panache-common</artifactId>\n"
"</dependency>\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:646
#, no-wrap
msgid ""
"// Enable Hibernate Reactive support\n"
"implementation(\"io.quarkus:quarkus-hibernate-reactive\")\n"
"// Pick your database reactive driver\n"
"implementation(\"io.quarkus:quarkus-reactive-pg-client\")\n"
"// FIXME: this will not be required in the future\n"
"implementation(\"io.quarkus:quarkus-hibernate-reactive-panache-common\")\n"
msgstr ""
"// Enable Hibernate Reactive support\n"
"implementation(\"io.quarkus:quarkus-hibernate-reactive\")\n"
"// Pick your database reactive driver\n"
"implementation(\"io.quarkus:quarkus-reactive-pg-client\")\n"
"// FIXME: this will not be required in the future\n"
"implementation(\"io.quarkus:quarkus-hibernate-reactive-panache-common\")\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:649
msgid "You can use any of the xref:hibernate-reactive.adoc#hr-getting-started[supported reactive drivers]."
msgstr "xref:hibernate-reactive.adoc#hr-getting-started[サポートされているリアクティブドライバー] のいずれかを使用できます。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:652
msgid "Make sure you configure your reactive datasource in your `application.properties` (although you don't have to in DEV mode: if you don't, a dev service will be provided for you):"
msgstr "`application.properties` でリアクティブデータソースを設定してください (ただし、開発モード の場合は必須ではありません。設定しない場合は dev service が提供されます):"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:658
#, no-wrap
msgid ""
"quarkus.datasource.username = quarkus_test\n"
"quarkus.datasource.password = quarkus_test\n"
"quarkus.datasource.reactive.url = vertx-reactive:postgresql://localhost/quarkus_test <1>\n"
msgstr ""
"quarkus.datasource.username = quarkus_test\n"
"quarkus.datasource.password = quarkus_test\n"
"quarkus.datasource.reactive.url = vertx-reactive:postgresql://localhost/quarkus_test <1>\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:661
msgid "Now, in your code, the only differences with a regular managed session entity are:"
msgstr "さて、コードでは、通常の管理されたセッションエンティティとの唯一の違いは次のとおりです。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:663
msgid "Your entity implements `PanacheEntity.Reactive`"
msgstr "エンティティは `PanacheEntity.Reactive` を実装します"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:664
msgid "Your repository extends `PanacheRepository.Reactive`"
msgstr "リポジトリは `PanacheRepository.Reactive` を拡張します"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:665
msgid "All the operations return a `Uni<T>` instead of `T`, which is the standard Mutiny reactive type"
msgstr "すべての操作は、`T` の代わりに `Uni<T>` を返します。これは標準の Mutiny リアクティブ型です。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:675
#: upstream/_guides/hibernate-panache-next.adoc:763
#, no-wrap
msgid ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import io.quarkus.hibernate.panache.PanacheRepository;\n"
"import io.quarkus.hibernate.panache.WithId;\n"
"import io.smallrye.mutiny.Uni;\n"
"import jakarta.persistence.Entity;\n"
"import org.hibernate.annotations.processing.Find;\n"
"import org.hibernate.annotations.processing.HQL;\n"
msgstr ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import io.quarkus.hibernate.panache.PanacheRepository;\n"
"import io.quarkus.hibernate.panache.WithId;\n"
"import io.smallrye.mutiny.Uni;\n"
"import jakarta.persistence.Entity;\n"
"import org.hibernate.annotations.processing.Find;\n"
"import org.hibernate.annotations.processing.HQL;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:684
#, no-wrap
msgid ""
"@Entity\n"
"public class Cat extends WithId.AutoLong implements PanacheEntity.Reactive {\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"
msgstr ""
"@Entity\n"
"public class Cat extends WithId.AutoLong implements PanacheEntity.Reactive {\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:692
#, no-wrap
msgid ""
"    public interface Repo extends PanacheRepository.Reactive<Cat, Long> {\n"
"        @Find\n"
"        Uni<Cat> findByName(String name);\n"
msgstr ""
"    public interface Repo extends PanacheRepository.Reactive<Cat, Long> {\n"
"        @Find\n"
"        Uni<Cat> findByName(String name);\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:695
#: upstream/_guides/hibernate-panache-next.adoc:783
#, no-wrap
msgid ""
"        @HQL(\"where breed = CUTE\")\n"
"        Uni<List<Cat>> findCute();\n"
msgstr ""
"        @HQL(\"where breed = CUTE\")\n"
"        Uni<List<Cat>> findCute();\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:698
#: upstream/_guides/hibernate-panache-next.adoc:786
#, no-wrap
msgid ""
"        @HQL(\"delete from Cat where name = :name\")\n"
"        Uni<Integer> deleteByName(String name);\n"
msgstr ""
"        @HQL(\"delete from Cat where name = :name\")\n"
"        Uni<Integer> deleteByName(String name);\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:703
#: upstream/_guides/hibernate-panache-next.adoc:791
#, no-wrap
msgid ""
"        @HQL(\"delete from Cat where breed = HAIRLESS\")\n"
"        Uni<Integer> deleteHairless();\n"
"    }\n"
"}\n"
msgstr ""
"        @HQL(\"delete from Cat where breed = HAIRLESS\")\n"
"        Uni<Integer> deleteHairless();\n"
"    }\n"
"}\n"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:708
msgid "And now when you want to use your entity or its repository, besides using `@WithTransaction` in place of `@Transactional`, you have to compose operations as you normally do in reactive code with Mutiny, but the operations are exactly the same otherwise:"
msgstr "エンティティーまたはそのリポジトリーを使用する場合、`@Transactional` の代わりに `@WithTransaction` を使用することに加えて、Mutiny を使用したリアクティブコードで通常行うように操作を構成する必要がありますが、それ以外の操作はまったく同じです。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:714
#: upstream/_guides/hibernate-panache-next.adoc:801
#, no-wrap
msgid ""
"import io.quarkus.hibernate.reactive.panache.common.WithTransaction;\n"
"import io.smallrye.mutiny.Uni;\n"
"import jakarta.inject.Inject;\n"
msgstr ""
"import io.quarkus.hibernate.reactive.panache.common.WithTransaction;\n"
"import io.smallrye.mutiny.Uni;\n"
"import jakarta.inject.Inject;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:730
#: upstream/_guides/hibernate-panache-next.adoc:816
#, no-wrap
msgid ""
"    @WithTransaction\n"
"    public Uni<Void> method() {\n"
"        Cat cat = new Cat();\n"
"        cat.name = \"Lucky\";\n"
"        cat.birth = LocalDate.of(2015, 01, 12);\n"
"        cat.breed = Cat.Breed.CUTE;\n"
msgstr ""
"    @WithTransaction\n"
"    public Uni<Void> method() {\n"
"        Cat cat = new Cat();\n"
"        cat.name = \"Lucky\";\n"
"        cat.birth = LocalDate.of(2015, 01, 12);\n"
"        cat.breed = Cat.Breed.CUTE;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:747
#, no-wrap
msgid ""
"        // Persist the cat\n"
"        return cat.persist()\n"
"                // Make a change, no need to update it\n"
"                .invoke(() -> cat.name = \"Luckynou\")\n"
"                // Find our cat\n"
"                .chain(() -> repo.findByName(\"Luckynou\"))\n"
"                // Find cute cats\n"
"                .chain((Cat foundCat) -> repo.findCute())\n"
"                // Delete our cat\n"
"                .chain((List<Cat> cuteCats) -> cat.delete())\n"
"                // Delete queries\n"
"                .chain(v -> repo.deleteByName(\"Lucky\"))\n"
"                .chain((Integer deletedCount) -> repo.deleteHairless())\n"
"                .replaceWithVoid();\n"
"    }\n"
"}\n"
msgstr ""
"        // Persist the cat\n"
"        return cat.persist()\n"
"                // Make a change, no need to update it\n"
"                .invoke(() -> cat.name = \"Luckynou\")\n"
"                // Find our cat\n"
"                .chain(() -> repo.findByName(\"Luckynou\"))\n"
"                // Find cute cats\n"
"                .chain((Cat foundCat) -> repo.findCute())\n"
"                // Delete our cat\n"
"                .chain((List<Cat> cuteCats) -> cat.delete())\n"
"                // Delete queries\n"
"                .chain(v -> repo.deleteByName(\"Lucky\"))\n"
"                .chain((Integer deletedCount) -> repo.deleteHairless())\n"
"                .replaceWithVoid();\n"
"    }\n"
"}\n"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:749
#, no-wrap
msgid "Reactive and stateless"
msgstr "リアクティブとステートレス"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:753
msgid "If you want to manage manually your entity changes, then you can use a stateless session by switching to the `PanacheEntity.Reactive.Stateless` for your entity, and `PanacheRepository.Reactive.Stateless`:"
msgstr "エンティティーの変更を手動で管理したい場合は、エンティティーに `PanacheEntity.Reactive.Stateless` を、リポジトリーに `PanacheRepository.Reactive.Stateless` を使用することで、ステートレスセッションを使用できます。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:772
#, no-wrap
msgid ""
"@Entity\n"
"public class Cat extends WithId.AutoLong implements PanacheEntity.Reactive.Stateless {\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"
msgstr ""
"@Entity\n"
"public class Cat extends WithId.AutoLong implements PanacheEntity.Reactive.Stateless {\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:780
#, no-wrap
msgid ""
"    public interface Repo extends PanacheRepository.Reactive.Stateless<Cat, Long> {\n"
"        @Find\n"
"        Uni<Cat> findByName(String name);\n"
msgstr ""
"    public interface Repo extends PanacheRepository.Reactive.Stateless<Cat, Long> {\n"
"        @Find\n"
"        Uni<Cat> findByName(String name);\n"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:795
msgid "And for your usage code, the only change is the standard use of manually calling `update()`, and using `insert()` instead of `persist()`:"
msgstr "使用コードについては、変更点は手動で `update()` を呼び出す標準的な使用方法と、`persist()` の代わりに `insert()` を使用することだけです。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:836
#, no-wrap
msgid ""
"        // Persist the cat\n"
"        return cat.insert()\n"
"                // Make a change, we need to update it\n"
"                .chain(() -> {\n"
"                    cat.name = \"Luckynou\";\n"
"                    return cat.update();\n"
"                })\n"
"                // Find our cat\n"
"                .chain(() -> repo.findByName(\"Luckynou\"))\n"
"                // Find cute cats\n"
"                .chain((Cat foundCat) -> repo.findCute())\n"
"                // Delete our cat\n"
"                .chain((List<Cat> cuteCats) -> cat.delete())\n"
"                // Delete queries\n"
"                .chain(v -> repo.deleteByName(\"Lucky\"))\n"
"                .chain((Integer deletedCount) -> repo.deleteHairless())\n"
"                .replaceWithVoid();\n"
"    }\n"
"}\n"
msgstr ""
"        // Persist the cat\n"
"        return cat.insert()\n"
"                // Make a change, we need to update it\n"
"                .chain(() -> {\n"
"                    cat.name = \"Luckynou\";\n"
"                    return cat.update();\n"
"                })\n"
"                // Find our cat\n"
"                .chain(() -> repo.findByName(\"Luckynou\"))\n"
"                // Find cute cats\n"
"                .chain((Cat foundCat) -> repo.findCute())\n"
"                // Delete our cat\n"
"                .chain((List<Cat> cuteCats) -> cat.delete())\n"
"                // Delete queries\n"
"                .chain(v -> repo.deleteByName(\"Lucky\"))\n"
"                .chain((Integer deletedCount) -> repo.deleteHairless())\n"
"                .replaceWithVoid();\n"
"    }\n"
"}\n"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:840
#, no-wrap
msgid "Combining blocking, reactive, managed, stateless code"
msgstr "ブロッキング、リアクティブ、管理、ステートレスコードの組み合わせ"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:846
msgid "Let's say you want to use an entity in a blocking managed session code, but also in a reactive stateless code: this is possible no matter which supertype of your entity you picked. You should pick the supertype that represents your majority of use-cases, but any one you pick, you can always obtain the alternative operations by using the `.statelessReactive()` method on the entity:"
msgstr "ブロックする管理セッションコードでエンティティーを使用したいが、リアクティブなステートレスコードでも使用したいとします。これは、どのエンティティーのスーパータイプを選択しても可能です。ほとんどのユースケースを表すスーパータイプを選択すべきですが、どれを選択しても、エンティティーで `.statelessReactive()` メソッドを使用することで、代替操作を常に取得できます。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:852
#, no-wrap
msgid ""
"import io.quarkus.hibernate.reactive.panache.common.WithTransaction;\n"
"import io.smallrye.mutiny.Uni;\n"
"import jakarta.transaction.Transactional;\n"
msgstr ""
"import io.quarkus.hibernate.reactive.panache.common.WithTransaction;\n"
"import io.smallrye.mutiny.Uni;\n"
"import jakarta.transaction.Transactional;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:863
#, no-wrap
msgid ""
"    @Transactional\n"
"    public void blockingManagedMethod() {\n"
"        Cat cat = new Cat();\n"
"        cat.name = \"Lucky\";\n"
"        cat.birth = LocalDate.of(2015, 01, 12);\n"
"        cat.breed = Cat.Breed.CUTE;\n"
msgstr ""
"    @Transactional\n"
"    public void blockingManagedMethod() {\n"
"        Cat cat = new Cat();\n"
"        cat.name = \"Lucky\";\n"
"        cat.birth = LocalDate.of(2015, 01, 12);\n"
"        cat.breed = Cat.Breed.CUTE;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:870
#, no-wrap
msgid ""
"        // Make a change, no need to update it\n"
"        cat.name = \"Luckynou\";\n"
"    }\n"
msgstr ""
"        // Make a change, no need to update it\n"
"        cat.name = \"Luckynou\";\n"
"    }\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:877
#, no-wrap
msgid ""
"    @WithTransaction\n"
"    public Uni<Void> reactiveStatelessMethod(Long catId) {\n"
"        Cat cat = new Cat();\n"
"        cat.name = \"Lucky\";\n"
"        cat.birth = LocalDate.of(2015, 01, 12);\n"
"        cat.breed = Cat.Breed.CUTE;\n"
msgstr ""
"    @WithTransaction\n"
"    public Uni<Void> reactiveStatelessMethod(Long catId) {\n"
"        Cat cat = new Cat();\n"
"        cat.name = \"Lucky\";\n"
"        cat.birth = LocalDate.of(2015, 01, 12);\n"
"        cat.breed = Cat.Breed.CUTE;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:885
#, no-wrap
msgid ""
"        // Insert the cat\n"
"        return cat.statelessReactive().insert()\n"
"                .chain(() -> {\n"
"                    // Make a change, we need to update it\n"
"                    cat.name = \"Luckynou\";\n"
"                    return cat.statelessReactive().update();\n"
"                });\n"
msgstr ""
"        // Insert the cat\n"
"        return cat.statelessReactive().insert()\n"
"                .chain(() -> {\n"
"                    // Make a change, we need to update it\n"
"                    cat.name = \"Luckynou\";\n"
"                    return cat.statelessReactive().update();\n"
"                });\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:888
#, no-wrap
msgid ""
"    }\n"
"}\n"
msgstr ""
"    }\n"
"}\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:891
msgid "All the alternative entity operations are available from these methods:"
msgstr "すべての代替エンティティ操作は、これらのメソッドから利用できます。"

#. type: Table
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:912
#, no-wrap
msgid ""
"|Session type|Entity accessor|Equivalent entity type\n"
"\n"
"|`Session`\n"
"|`.managedBlocking()`\n"
"|`PanacheEntity.Managed`\n"
"\n"
"|`StatelessSession`\n"
"|`.statelessBlocking()`\n"
"|`PanacheEntity.Stateless`\n"
"\n"
"|`Mutiny.Session`\n"
"|`.managedReactive()`\n"
"|`PanacheEntity.Reactive`\n"
"\n"
"|`Mutiny.StatelessSession`\n"
"|`.statelessReactive()`\n"
"|`PanacheEntity.Reactive.Stateless`\n"
"\n"
msgstr ""
"|セッション型|エンティティーアクセサー|同等のエンティティー型\n"
"\n"
"|`Session`\n"
"|`.managedBlocking()`\n"
"|`PanacheEntity.Managed`\n"
"\n"
"|`StatelessSession`\n"
"|`.statelessBlocking()`\n"
"|`PanacheEntity.Stateless`\n"
"\n"
"|`Mutiny.Session`\n"
"|`.managedReactive()`\n"
"|`PanacheEntity.Reactive`\n"
"\n"
"|`Mutiny.StatelessSession`\n"
"|`.statelessReactive()`\n"
"|`PanacheEntity.Reactive.Stateless`\n"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:916
msgid "Similarly, for all the repository operations, you can obtain alternate repositories for your entity from the generated metamodel accessors, or by injecting them with `@Inject`:"
msgstr "同様に、すべてのリポジトリー操作についても、生成されたメタモデルアクセサーからエンティティーの代替リポジトリーを取得するか、`@Inject` でインジェクトすることで取得できます。"

#. type: Table
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:937
#, no-wrap
msgid ""
"|Session type|Metamodel accessor|Repository type\n"
"\n"
"|`Session`\n"
"|`Cat_.managedBlocking()`\n"
"|`PanacheRepository.Managed<Cat, Long>`\n"
"\n"
"|`StatelessSession`\n"
"|`Cat_.statelessBlocking()`\n"
"|`PanacheRepository.Stateless<Cat, Long>`\n"
"\n"
"|`Mutiny.Session`\n"
"|`Cat_.managedReactive()`\n"
"|`PanacheRepository.Reactive<Cat, Long>`\n"
"\n"
"|`Mutiny.StatelessSession`\n"
"|`Cat_.statelessReactive()`\n"
"|`PanacheRepository.Reactive.Stateless<Cat, Long>`\n"
"\n"
msgstr ""
"|セッション型|メタモデルアクセサー|リポジトリー型\n"
"\n"
"|`Session`\n"
"|`Cat_.managedBlocking()`\n"
"|`PanacheRepository.Managed<Cat, Long>`\n"
"\n"
"|`StatelessSession`\n"
"|`Cat_.statelessBlocking()`\n"
"|`PanacheRepository.Stateless<Cat, Long>`\n"
"\n"
"|`Mutiny.Session`\n"
"|`Cat_.managedReactive()`\n"
"|`PanacheRepository.Reactive<Cat, Long>`\n"
"\n"
"|`Mutiny.StatelessSession`\n"
"|`Cat_.statelessReactive()`\n"
"|`PanacheRepository.Reactive.Stateless<Cat, Long>`\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:940
msgid "But you can also define any number of repositories for your custom operations within your entity:"
msgstr "しかし、エンティティ内でカスタム操作のための任意の数のリポジトリを定義することもできます。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:949
#, no-wrap
msgid ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import io.quarkus.hibernate.panache.PanacheRepository;\n"
"import io.smallrye.mutiny.Uni;\n"
"import jakarta.persistence.Entity;\n"
"import org.hibernate.annotations.processing.Find;\n"
"import org.hibernate.annotations.processing.HQL;\n"
msgstr ""
"import io.quarkus.hibernate.panache.PanacheEntity;\n"
"import io.quarkus.hibernate.panache.PanacheRepository;\n"
"import io.smallrye.mutiny.Uni;\n"
"import jakarta.persistence.Entity;\n"
"import org.hibernate.annotations.processing.Find;\n"
"import org.hibernate.annotations.processing.HQL;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:967
#, no-wrap
msgid ""
"    public interface Repo extends PanacheRepository<Cat> {\n"
"        @Find\n"
"        Cat findByName(String name);\n"
"    }\n"
msgstr ""
"    public interface Repo extends PanacheRepository<Cat> {\n"
"        @Find\n"
"        Cat findByName(String name);\n"
"    }\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:973
#, no-wrap
msgid ""
"    public interface TheOtherRepo extends PanacheRepository.Reactive.Stateless<Cat, Long> {\n"
"        @Find\n"
"        Uni<Cat> findByName(String name);\n"
"    }\n"
"}\n"
msgstr ""
"    public interface TheOtherRepo extends PanacheRepository.Reactive.Stateless<Cat, Long> {\n"
"        @Find\n"
"        Uni<Cat> findByName(String name);\n"
"    }\n"
"}\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:976
msgid "And then you can inject both types of repositories:"
msgstr "そして、両方の種類のリポジトリを注入できます。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:983
#, no-wrap
msgid ""
"import io.quarkus.hibernate.reactive.panache.common.WithTransaction;\n"
"import io.smallrye.mutiny.Uni;\n"
"import jakarta.inject.Inject;\n"
"import jakarta.transaction.Transactional;\n"
msgstr ""
"import io.quarkus.hibernate.reactive.panache.common.WithTransaction;\n"
"import io.smallrye.mutiny.Uni;\n"
"import jakarta.inject.Inject;\n"
"import jakarta.transaction.Transactional;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:991
#, no-wrap
msgid ""
"    @Inject\n"
"    Cat.TheOtherRepo theOtherRepo;\n"
msgstr ""
"    @Inject\n"
"    Cat.TheOtherRepo theOtherRepo;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:996
#, no-wrap
msgid ""
"    @Transactional\n"
"    public void blockingManagedMethod() {\n"
"        Cat cat = repo.findByName(\"Lucky\");\n"
"    }\n"
msgstr ""
"    @Transactional\n"
"    public void blockingManagedMethod() {\n"
"        Cat cat = repo.findByName(\"Lucky\");\n"
"    }\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1004
#, no-wrap
msgid ""
"    @WithTransaction\n"
"    public Uni<Void> reactiveStatelessMethod() {\n"
"        return theOtherRepo.findByName(\"Lucky\")\n"
"                .invoke(cat -> System.err.println(cat))\n"
"                .replaceWithVoid();\n"
"    }\n"
"}\n"
msgstr ""
"    @WithTransaction\n"
"    public Uni<Void> reactiveStatelessMethod() {\n"
"        return theOtherRepo.findByName(\"Lucky\")\n"
"                .invoke(cat -> System.err.println(cat))\n"
"                .replaceWithVoid();\n"
"    }\n"
"}\n"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1008
msgid "you can of course also use the generated metamodel accessors instead of injecting these repositories, with `Cat_.repo()` and `Cat_.theOtherRepo()`."
msgstr "もちろん、これらのリポジトリーをインジェクトする代わりに、`Cat_.repo()` や `Cat_.theOtherRepo()` を使用して生成されたメタモデルアクセサーを使うこともできます。"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:1009
#, no-wrap
msgid "Recap"
msgstr "要約"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1014
msgid "Here is a table listing all the options you have for your entity and repository supertypes, depending on which model of operation you prefer, and which ID type you want. Remember you don't have to extend `WithId<Id>` if you define your own ID entity field:"
msgstr "操作モデルの好みと希望する ID 型に応じて、エンティティーとリポジトリーのスーパータイプに利用できるすべてのオプションをまとめた表を以下に示します。独自の ID エンティティーフィールドを定義する場合、`WithId<Id>` を拡張する必要がないことを忘れないでください。"

#. type: Table
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1050
#, no-wrap
msgid ""
"|Session type|ID type|Entity superclass|Entity superinterface|Repository supertype\n"
"\n"
"|`Session` (managed, blocking)\n"
"|`Long`\n"
"|`PanacheEntity`\n"
"|\n"
"|`PanacheRepository<Entity>`\n"
"\n"
"|`Session` (managed, blocking)\n"
"|`Id`\n"
"|`WithId<Id>`\n"
"|`PanacheEntity.Managed`\n"
"|`PanacheRepository.Managed<Entity, Id>`\n"
"\n"
"|`StatelessSession` (stateless, blocking)\n"
"|`Id`\n"
"|`WithId<Id>`\n"
"|`PanacheEntity.Stateless`\n"
"|`PanacheRepository.Stateless<Entity, Id>`\n"
"\n"
"|`Mutiny.Session` (managed, reactive)\n"
"|`Id`\n"
"|`WithId<Id>`\n"
"|`PanacheEntity.Reactive`\n"
"|`PanacheRepository.Reactive<Entity, Id>`\n"
"\n"
"\n"
"|`Mutiny.StatelessSession` (stateless, reactive)\n"
"|`Id`\n"
"|`WithId<Id>`\n"
"|`PanacheEntity.Reactive.Stateless`\n"
"|`PanacheRepository.Reactive.Stateless<Entity, Id>`\n"
"\n"
msgstr ""
"|セッション型|ID 型|エンティティーのスーパークラス|エンティティーのスーパーインターフェース|リポジトリーのスーパータイプ\n"
"\n"
"|`Session` (管理、ブロッキング)\n"
"|`Long`\n"
"|`PanacheEntity`\n"
"|\n"
"|`PanacheRepository<Entity>`\n"
"\n"
"|`Session` (管理、ブロッキング)\n"
"|`Id`\n"
"|`WithId<Id>`\n"
"|`PanacheEntity.Managed`\n"
"|`PanacheRepository.Managed<Entity, Id>`\n"
"\n"
"|`StatelessSession` (ステートレス、ブロッキング)\n"
"|`Id`\n"
"|`WithId<Id>`\n"
"|`PanacheEntity.Stateless`\n"
"|`PanacheRepository.Stateless<Entity, Id>`\n"
"\n"
"|`Mutiny.Session` (管理、リアクティブ)\n"
"|`Id`\n"
"|`WithId<Id>`\n"
"|`PanacheEntity.Reactive`\n"
"|`PanacheRepository.Reactive<Entity, Id>`\n"
"\n"
"\n"
"|`Mutiny.StatelessSession` (ステートレス、リアクティブ)\n"
"|`Id`\n"
"|`WithId<Id>`\n"
"|`PanacheEntity.Reactive.Stateless`\n"
"|`PanacheRepository.Reactive.Stateless<Entity, Id>`\n"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:1052
#, no-wrap
msgid "Startup code"
msgstr "起動コード"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1055
msgid "For blocking operations, invoking startup code is pretty trivial:"
msgstr "ブロッキング操作の場合、起動コードの呼び出しはかなり簡単です。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1071
msgid "For reactive operations, it is fairly similar:"
msgstr "リアクティブ操作の場合、かなり似ています。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1077
#, no-wrap
msgid ""
"import io.quarkus.hibernate.reactive.panache.common.WithTransaction;\n"
"import io.quarkus.runtime.Startup;\n"
"import io.smallrye.mutiny.Uni;\n"
msgstr ""
"import io.quarkus.hibernate.reactive.panache.common.WithTransaction;\n"
"import io.quarkus.runtime.Startup;\n"
"import io.smallrye.mutiny.Uni;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1085
#, no-wrap
msgid ""
"public class OnStart {\n"
"    @Startup\n"
"    @WithTransaction\n"
"    Uni<Void> startupMethod(){\n"
"        return Cat_.repo().deleteAll().replaceWithVoid();\n"
"    }\n"
"}\n"
msgstr ""
"public class OnStart {\n"
"    @Startup\n"
"    @WithTransaction\n"
"    Uni<Void> startupMethod(){\n"
"        return Cat_.repo().deleteAll().replaceWithVoid();\n"
"    }\n"
"}\n"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:1087
#, no-wrap
msgid "Jakarta Data"
msgstr "Jakarta Data"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1090
msgid "Naturally, you can also use link:{jakarta-data-spec-url}[Jakarta Data] to define your repositories. For this you need to import the module:"
msgstr "当然ながら、link:{jakarta-data-spec-url}[Jakarta Data] を使用してリポジトリを定義することもできます。そのためには、モジュールをインポートする必要があります。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1098
#, no-wrap
msgid ""
"<dependency>\n"
"    <groupId>jakarta.data</groupId>\n"
"    <artifactId>jakarta.data-api</artifactId>\n"
"</dependency>\n"
msgstr ""
"<dependency>\n"
"    <groupId>jakarta.data</groupId>\n"
"    <artifactId>jakarta.data-api</artifactId>\n"
"</dependency>\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1104
#, no-wrap
msgid "implementation 'jakarta.data:jakarta.data-api'\n"
msgstr "implementation 'jakarta.data:jakarta.data-api'\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1107
msgid "And then you can write your entity as described before, extending a variant of `PanacheEntity` or not, as you wish."
msgstr "そして、前述のとおりエンティティを記述できます。`PanacheEntity` のバリアントを拡張するかどうかは任意です。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1111
msgid "As for the repositories, given that Jakarta Data 1.0 only supports the stateless variants (managed entities are being added to the upcoming 1.1 version), we recommend that you stick to the `PanacheRepository` variants in order to support stateless or managed entities. Both blocking and reactive variants are supported, though."
msgstr "リポジトリーに関しては、Jakarta Data 1.0 はステートレスなバリアントのみをサポートしているため (管理対象エンティティーは来るべき 1.1 バージョンに追加される予定です)、ステートレスまたは管理対象エンティティーをサポートするために `PanacheRepository` バリアントを使用することをお勧めします。ただし、ブロッキングとリアクティブの両方のバリアントがサポートされています。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1114
msgid "Otherwise, just replace `@HQL` with `@Query` and change the package import of `@Find`, and you can even write `@Delete` finder methods:"
msgstr "それ以外の場合は、`@HQL` を `@Query` に置き換え、`@Find` のパッケージインポートを変更するだけで、`@Delete` ファインダーメソッドも記述できます。"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1118
#, no-wrap
msgid "import io.quarkus.hibernate.panache.PanacheRepository;\n"
msgstr "import io.quarkus.hibernate.panache.PanacheRepository;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1125
#, no-wrap
msgid ""
"import jakarta.data.repository.Delete;\n"
"import jakarta.data.repository.Find;\n"
"import jakarta.data.repository.Query;\n"
"import jakarta.persistence.Entity;\n"
"import jakarta.persistence.GeneratedValue;\n"
"import jakarta.persistence.Id;\n"
msgstr ""
"import jakarta.data.repository.Delete;\n"
"import jakarta.data.repository.Find;\n"
"import jakarta.data.repository.Query;\n"
"import jakarta.persistence.Entity;\n"
"import jakarta.persistence.GeneratedValue;\n"
"import jakarta.persistence.Id;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1137
#, no-wrap
msgid ""
"@Entity\n"
"public class Cat {\n"
"    @Id\n"
"    @GeneratedValue\n"
"    public Long id;\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"
msgstr ""
"@Entity\n"
"public class Cat {\n"
"    @Id\n"
"    @GeneratedValue\n"
"    public Long id;\n"
"    public String name;\n"
"    public LocalDate birth;\n"
"    public Breed breed;\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1145
#, no-wrap
msgid ""
"    public interface Repo extends PanacheRepository.Stateless<Cat, Long> {\n"
"        @Find <1>\n"
"        Cat findByName(String name);\n"
msgstr ""
"    public interface Repo extends PanacheRepository.Stateless<Cat, Long> {\n"
"        @Find <1>\n"
"        Cat findByName(String name);\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1148
#, no-wrap
msgid ""
"        @Query(\"where breed = CUTE\") <2>\n"
"        List<Cat> findCute();\n"
msgstr ""
"        @Query(\"where breed = CUTE\") <2>\n"
"        List<Cat> findCute();\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1151
#, no-wrap
msgid ""
"        @Delete <3>\n"
"        long deleteByName(String name);\n"
msgstr ""
"        @Delete <3>\n"
"        long deleteByName(String name);\n"

#. type: delimited block -
#: upstream/_guides/hibernate-panache-next.adoc:1156
#, no-wrap
msgid ""
"        @Query(\"delete from Cat where breed = HAIRLESS\") <4>\n"
"        long deleteHairless();\n"
"    }\n"
"}\n"
msgstr ""
"        @Query(\"delete from Cat where breed = HAIRLESS\") <4>\n"
"        long deleteHairless();\n"
"    }\n"
"}\n"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1158
msgid "This is a regular finder method"
msgstr "これは通常のファインダーメソッドです"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1159
msgid "Use `@Query` in place of `@HQL`, they're the same everything"
msgstr "`@HQL` の代わりに `@Query` を使用します。これらは全く同じです。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1161
msgid "You can write `delete` finder methods. Just like finder methods, except their action is to delete entities, optionally returning how many were deleted."
msgstr "`delete` ファインダーメソッドを記述できます。これはファインダーメソッドと似ていますが、そのアクションはエンティティーを削除することであり、オプションで削除された数を返します。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1162
msgid "You can always explicitly write delete methods as query methods."
msgstr "常に明示的に削除メソッドをクエリメソッドとして記述できます。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1165
msgid "But otherwise you can still make your entity extend `PanacheEntity` or any of its variants, and you still get your repository injectable, or via the `Cat_.repo()` accessor."
msgstr "しかし、それ以外の場合でも、エンティティーを `PanacheEntity` またはそのバリアントのいずれかを拡張させることができ、リポジトリーをインジェクト可能にしたり、`Cat_.repo()` アクセサーを介して取得したりできます。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1169
msgid "Please refer to the corresponding https://hibernate.org/repositories/[Hibernate Data Repositories] and link:{jakarta-data-spec-url}[Jakarta Data] guides to learn what else they have to offer."
msgstr "その他の提供機能については、対応する https://hibernate.org/repositories/[Hibernate Data Repositories] および link:{jakarta-data-spec-url}[Jakarta Data] ガイドを参照してください。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1172
msgid "You can also use the reactive variants by returning `Uni` types from your repository methods, or add other types of repositories in your entity to support managed entities."
msgstr "リポジトリーメソッドから `Uni` 型を返すことでリアクティブバリアントを使用したり、管理対象エンティティーをサポートするためにエンティティーに他のタイプのリポジトリーを追加したりすることもできます。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1175
msgid "You can also use <<Use stateless sessions,Panache Stateless repositories>> or <<Reactive and stateless,Panache Stateless Reactive repositories>>."
msgstr "<<Use stateless sessions,Panache ステートレスリポジトリー>> または <<Reactive and stateless,Panache ステートレスリアクティブリポジトリー>> を使用することもできます。"

#. type: Title ==
#: upstream/_guides/hibernate-panache-next.adoc:1176
#, no-wrap
msgid "HQL, JD-QL, Jakarta-QL, Panache-QL"
msgstr "HQL、JD-QL、Jakarta-QL、Panache-QL"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1179
msgid "There are different query languages used in this API:"
msgstr "この API で使用されるクエリー言語には、いくつかの種類があります。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1182
msgid "The link:https://docs.hibernate.org/orm/{hibernate-orm-version-major-minor}/querylanguage/html_single/[Hibernate Query Language] (HQL), which is the query language used by Hibernate, supported by the `@HQL` annotation."
msgstr "Hibernate が使用するクエリー言語である link:https://docs.hibernate.org/orm/{hibernate-orm-version-major-minor}/querylanguage/html_single/[Hibernate Query Language] (HQL) は、`@HQL` アノテーションでサポートされています。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1185
msgid "The link:{jakarta-persistence-spec-url}#a4665[Jakarta Persistence Query Language] (JP-QL), which is a subset of the Hibernate Query Language. It is currently being moved to its own spec called link:https://jakarta.ee/specifications/query/1.0/jakarta-query-1.0-m1[Jakarta Query]."
msgstr "Hibernate Query Language のサブセットである link:{jakarta-persistence-spec-url}#a4665[Jakarta Persistence Query Language] (JP-QL)。現在、link:https://jakarta.ee/specifications/query/1.0/jakarta-query-1.0-m1[Jakarta Query] と呼ばれる独自の仕様に移行中です。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1187
msgid "The link:{jakarta-data-spec-url}#_jakarta_data_query_language[Jakarta Data Query Language] (JD-QL), which is a subset of the Jakarta Persistence Query Language, supported by the `@Query` annotation."
msgstr "Jakarta Persistence Query Language のサブセットである link:{jakarta-data-spec-url}#_jakarta_data_query_language[Jakarta Data Query Language] (JD-QL) は、`@Query` アノテーションでサポートされています。"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1189
msgid "The Panache Query Language, which is a superset of the Hibernate Query Language adding very few shortcuts, which is supported in all the `PanacheRepository` queries."
msgstr "Hibernate Query Language のスーパーセットであり、ごくわずかなショートカットを追加した Panache Query Language は、すべての `PanacheRepository` クエリーでサポートされています。"

#. type: Title ===
#: upstream/_guides/hibernate-panache-next.adoc:1190
#, no-wrap
msgid "Panache Query Language"
msgstr "Panache Query Language"

#. type: Plain text
#. mt: gemini
#: upstream/_guides/hibernate-panache-next.adoc:1194
msgid "Normally, most HQL queries are of this form: `from EntityName [where ...] [order by ...]`, with optional elements at the end."
msgstr "通常、ほとんどの HQL クエリーは、`from EntityName [where ...] [order by ...]` という形式で、末尾にオプション要素があります。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1196
msgid "If your select query does not start with `from`, `select` or `with`, we support the following additional forms:"
msgstr "select クエリーが `from`、`select` または `with` で始まらない場合は、次の追加形式をサポートしています。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1198
msgid "`order by ...` which will expand to `from EntityName order by ...`"
msgstr "`order by ...` は `from EntityName order by ...` に展開されます"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1199
msgid "`<singleAttribute>` (and single parameter) which will expand to `from EntityName where <singleAttribute> = ?`"
msgstr "`<singleAttribute>` (および単一のパラメータ) は `from EntityName where <singleAttribute> = ?` に展開されます"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1200
msgid "`where <query>` will expand to `from EntityName where <query>`"
msgstr "`where <query>` は `from EntityName where <query>` に展開されます"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1201
msgid "`<query>` will expand to `from EntityName where <query>`"
msgstr "`<query>` は `from EntityName where <query>` に展開されます"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1203
msgid "If your update query does not start with `update`, we support the following additional forms:"
msgstr "更新クエリーが `update` で始まらない場合は、次の追加形式をサポートしています。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1205
msgid "`from EntityName ...` which will expand to `update EntityName ...`"
msgstr "`from EntityName ...` は `update EntityName ...` に展開されます"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1206
msgid "`set? <singleAttribute>` (and single parameter) which will expand to `update EntityName set <singleAttribute> = ?`"
msgstr "`set? <singleAttribute>` (および単一のパラメータ) は `update EntityName set <singleAttribute> = ?` に展開されます"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1207
msgid "`set? <update-query>` will expand to `update EntityName set <update-query>`"
msgstr "`set? <update-query>` は `update EntityName set <update-query>` に展開されます"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1209
msgid "If your delete query does not start with `delete`, we support the following additional forms:"
msgstr "削除クエリーが `delete` で始まらない場合は、次の追加形式をサポートしています。"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1211
msgid "`from EntityName ...` which will expand to `delete from EntityName ...`"
msgstr "`from EntityName ...` は `delete from EntityName ...` に展開されます"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1212
msgid "`<singleAttribute>` (and single parameter) which will expand to `delete from EntityName where <singleAttribute> = ?`"
msgstr "`<singleAttribute>` (および単一のパラメータ) は `delete from EntityName where <singleAttribute> = ?` に展開されます"

#. type: Plain text
#: upstream/_guides/hibernate-panache-next.adoc:1212
msgid "`<query>` will expand to `delete from EntityName where <query>`"
msgstr "`<query>` は `delete from EntityName where <query>` に展開されます"
