#: _posts/2026-05-19-quarkus-insights-248-ddd-hexagonal-architecture.adoc
#, fuzzy
msgid "Close Collaboration Pattern"
msgstr "緊密な連携パターン"

#. type: Plain text
#. mt: deepl
#: _posts/2026-05-19-quarkus-insights-248-ddd-hexagonal-architecture.adoc
#, fuzzy
msgid "When teams work closely together:"
msgstr "チームが緊密に協力するとき"

