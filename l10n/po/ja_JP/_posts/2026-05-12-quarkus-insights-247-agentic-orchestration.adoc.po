msgstr ""

#. type: Plain text
#: _posts/2026-05-12-quarkus-insights-247-agentic-orchestration.adoc
msgid "Rather than using traditional LangChain4j annotations for sequential or parallel agent pipelines within a single application, Jonathan implemented a **distributed round-table architecture** using https://nats.io/[NATS] messaging:"
msgstr ""

#. type: Title ==
#: _posts/2026-05-12-quarkus-insights-247-agentic-orchestration.adoc
msgid "Traditional Approach (Monolithic)"
msgstr ""

#. type: Title ==
#: _posts/2026-05-12-quarkus-insights-247-agentic-orchestration.adoc
msgid "Distributed Approach (Kubemoot)"
msgstr ""

#. type: Plain text
#: _posts/2026-05-12-quarkus-insights-247-agentic-orchestration.adoc
msgid "**Agents as Kubernetes pods**: Each agent runs as an independent container"
msgstr ""

#. type: Plain text
#: _posts/2026-05-12-quarkus-insights-247-agentic-orchestration.adoc
msgid "**NATS messaging**: Agents communicate via distributed messaging (not inter-process)"
msgstr ""

#. type: Plain text
#: _posts/2026-05-12-quarkus-insights-247-agentic-orchestration.adoc
msgid "**Democratic coordination**: Agents self-select to contribute based on their expertise"
msgstr ""

#. type: Plain text
#: _posts/2026-05-12-quarkus-insights-247-agentic-orchestration.adoc
