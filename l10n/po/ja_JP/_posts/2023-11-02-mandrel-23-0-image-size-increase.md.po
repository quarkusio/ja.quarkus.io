#, fuzzy, no-wrap
msgid ""
"git clone https://github.com/quarkus-qe/quarkus-startstop\n"
"cd quarkus-startstop\n"
"git checkout a8bae846881607e376c7c8a96116b6b50ee50b70\n"
msgstr "git clone https://github.com/quarkus-qe/quarkus-startstop cd quarkus-startstop git checkout a8bae846881607e376c7c8a96116b6b50ee50b70"

