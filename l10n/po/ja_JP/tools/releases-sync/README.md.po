#. type: Title #
#: tools/releases-sync/README.md:1
#, no-wrap
msgid "Release Sync"
msgstr ""

#. type: Plain text
#: tools/releases-sync/README.md:4
#, no-wrap
msgid "Keeps `_data/releases.yaml` patch versions current by fetching from the GitHub API.\n"
msgstr ""

#. type: Title ##
#: tools/releases-sync/README.md:5
#, no-wrap
msgid "What it does"
msgstr ""

#. type: Bullet: '1. '
#: tools/releases-sync/README.md:11
#, no-wrap
msgid "Fetches releases from GitHub API\n"
msgstr ""

#. type: Bullet: '2. '
#: tools/releases-sync/README.md:11
#, no-wrap
msgid "Groups by minor version (3.36.x becomes \"3.36\")\n"
msgstr ""

#. type: Bullet: '3. '
#: tools/releases-sync/README.md:11
#, no-wrap
msgid "Updates `latest_patch` and `latest_patch_date` for each minor\n"
msgstr ""

#. type: Bullet: '4. '
#: tools/releases-sync/README.md:11
#, no-wrap
msgid "Preserves all manually-edited fields\n"
msgstr ""

#. type: Title ##
#: tools/releases-sync/README.md:12
#, no-wrap
msgid "Field ownership"
msgstr ""

#. type: Plain text
#: tools/releases-sync/README.md:18
#, no-wrap
msgid ""
"**Automated (updated by this script):**\n"
"- `latest_patch` - Latest patch version\n"
"- `latest_patch_date` - Date of latest patch\n"
"- `release_date` - Date of first release in this minor\n"
msgstr ""

#. type: Plain text
#: tools/releases-sync/README.md:28
#, no-wrap
msgid ""
"**Manual (edit directly in releases.yaml):**\n"
"- `policy` section - LTS cadence, support durations, descriptions\n"
"- `support_providers` section - Commercial support providers\n"
"- `eol_support` section - EOL support options\n"
"- `lts` - Whether this is an LTS release\n"
"- `eol_date` - End of life date\n"
"- `link` - Blog post link\n"
"- `rhbq_eol`, `ibm_eol` - Commercial EOL dates\n"
"- `upcoming` - For releases not yet published\n"
msgstr ""

#. type: Title ##
#: tools/releases-sync/README.md:29
#, no-wrap
msgid "Running locally"
msgstr ""

#. type: Fenced code block (bash)
#: tools/releases-sync/README.md:31
#, no-wrap
msgid ""
"# Dry run (show what would change)\n"
"GITHUB_TOKEN=\"your_token\" jbang tools/releases-sync/main.java --dry-run\n"
"\n"
"# Actually update\n"
"GITHUB_TOKEN=\"your_token\" jbang tools/releases-sync/main.java\n"
msgstr ""

#. type: Title ##
#: tools/releases-sync/README.md:39
#, no-wrap
msgid "CI"
msgstr ""

#. type: Plain text
#: tools/releases-sync/README.md:44
#, no-wrap
msgid ""
"The workflow at `.github/workflows/sync-releases.yml`:\n"
"- Runs on a schedule to update patch versions\n"
"- Runs in dry-run mode on PRs touching `tools/releases-sync/` or the workflow itself\n"
msgstr ""

#. type: Title ##
#: tools/releases-sync/README.md:45
#, no-wrap
msgid "Environment variables"
msgstr ""

#. type: Bullet: '- '
#: tools/releases-sync/README.md:51
#, no-wrap
msgid "`GITHUB_TOKEN` - GitHub API token (required)\n"
msgstr ""

#. type: Bullet: '- '
#: tools/releases-sync/README.md:51
#, no-wrap
msgid "`RELEASES_ORG` - GitHub org (default: quarkusio)\n"
msgstr ""

#. type: Bullet: '- '
#: tools/releases-sync/README.md:51
#, no-wrap
msgid "`RELEASES_REPO` - GitHub repo (default: quarkus)\n"
msgstr ""

#. type: Bullet: '- '
#: tools/releases-sync/README.md:51
#, no-wrap
msgid "`RELEASES_INPUT` - Input file (default: _data/releases.yaml)\n"
msgstr ""

#. type: Bullet: '- '
#: tools/releases-sync/README.md:51
#, no-wrap
msgid "`RELEASES_OUTPUT` - Output file (default: _data/releases.yaml)\n"
msgstr ""
