#: _includes/catalog-detail-band.html:48
msgid "Default"
msgstr "デフォルト"

#. type: Content of: <div><div><div><table><tr><td>
#: _includes/catalog-detail-band.html:51 _includes/catalog-detail-band.html:56
#: _includes/catalog-detail-band.html:61 _includes/catalog-detail-band.html:66
#: _includes/catalog-detail-band.html:71
msgid "<code>quarkus.jberet.repository</code>"
msgstr "<code>quarkus.jberet.repository</code>"

#. type: Content of: <div><div><div><table><tr><td><p>
#: _includes/catalog-detail-band.html:51 _includes/catalog-detail-band.html:56
#: _includes/catalog-detail-band.html:61 _includes/catalog-detail-band.html:66
