#. type: Content of: <div><div><div><h2>
#. mt: gemini
#: _includes/get-started-code-steps.html:5
msgid "Step <span class=\"step-no\">1</span>"
msgstr "ステップ <span class=\"step-no\">1</span>"

#. type: Content of: <div><div><div><h3>
#. mt: gemini
#: _includes/get-started-code-steps.html:8
msgid "Install via Command Line Interface"
msgstr "コマンドラインインターフェースを介したインストール"

#. type: Content of: <div><div><div><p>
#. mt: gemini
#: _includes/get-started-code-steps.html:9
msgid "Open your favorite terminal and use JBang to install the Quarkus CLI. You do not need to have Java installed first."
msgstr "お好みのターミナルを開き、JBang を使用して Quarkus CLI をインストールします。Java が事前にインストールされている必要はありません。"

#. type: Content of: <div><div><div><h4>
#. mt: gemini
#: _includes/get-started-code-steps.html:10
msgid "For Linux, macOS, and Windows (using WSL or bash compatible shell like Cygwin or MinGW)"
msgstr "Linux、macOS、Windows (WSL または Cygwin や MinGW のような bash 互換シェルを使用) の場合"

#. type: Content of: <div><div><div><div><div><pre>
#. mt: gemini
#: _includes/get-started-code-steps.html:13
#, no-wrap
msgid ""
"<code>curl -Ls https://sh.jbang.dev | bash -s - trust add https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/\n"
"curl -Ls https://sh.jbang.dev | bash -s - app install --fresh --force quarkus@quarkusio</code>"
msgstr ""
"<code>curl -Ls https://sh.jbang.dev | bash -s - trust add https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/\n"
"curl -Ls https://sh.jbang.dev | bash -s - app install --fresh --force quarkus@quarkusio</code>"

#. type: Content of: <div><div><div><h4>
#. mt: gemini
#: _includes/get-started-code-steps.html:17
msgid "For Windows using Powershell"
msgstr "Powershell を使用する Windows の場合"

#. type: Content of: <div><div><div><div><div><pre>
#. mt: gemini
#: _includes/get-started-code-steps.html:20
#, no-wrap
msgid ""
"<code>iex \"& { $(iwr https://ps.jbang.dev) } trust add https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/\"\n"
"iex \"& { $(iwr https://ps.jbang.dev) } app install --fresh --force quarkus@quarkusio\"</code>"
msgstr ""
"<code>iex \"& { $(iwr https://ps.jbang.dev) } trust add https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/\"\n"
"iex \"& { $(iwr https://ps.jbang.dev) } app install --fresh --force quarkus@quarkusio\"</code>"

#. type: Content of: <div><div><div><p>
#. mt: gemini
#: _includes/get-started-code-steps.html:24
msgid "If it's your first time to install, you'll need to restart your shell."
msgstr "初めてインストールする場合は、シェルを再起動する必要があります。"

#. type: Content of: <div><div><div><h4>
#. mt: gemini
#: _includes/get-started-code-steps.html:25
msgid "Or, you can also install the CLI with SDKMAN!"
msgstr "あるいは、SDKMAN! を使用して CLI をインストールすることもできます。"

#. type: Content of: <div><div><div><div><div><pre>
#. mt: gemini
#: _includes/get-started-code-steps.html:28
#, no-wrap
msgid "<code>sdk install quarkus</code>"
msgstr "<code>sdk install quarkus</code>"

#. type: Content of: <div><div><div><h4>
#. mt: gemini
#: _includes/get-started-code-steps.html:31
msgid "For more options, such as Homebrew or Chocolatey, see <a href=\"/guides/cli-tooling\">the Quarkus CLI guide</a>."
msgstr "Homebrew や Chocolatey などのその他のオプションについては、<a href=\"/guides/cli-tooling\">Quarkus CLI ガイド</a>を参照してください。"

#. type: Content of: <div><div><div><h2>
#. mt: gemini
#: _includes/get-started-code-steps.html:34
msgid "Step <span class=\"step-no\">2</span>"
msgstr "ステップ <span class=\"step-no\">2</span>"

#. type: Content of: <div><div><div><h3>
#. mt: gemini
#: _includes/get-started-code-steps.html:37
msgid "Create the Getting Started Application"
msgstr "入門アプリケーションの作成"

#. type: Content of: <div><div><div><p>
#. mt: gemini
#: _includes/get-started-code-steps.html:38
#: _includes/get-started-code-steps.html:54
msgid "Run this script in your CLI:"
msgstr "CLI でこのスクリプトを実行します。"

#. type: Content of: <div><div><div><div><div><div><div><pre>
#. mt: gemini
#: _includes/get-started-code-steps.html:43
#, no-wrap
msgid "<code>quarkus create && cd code-with-quarkus</code>"
msgstr "<code>quarkus create && cd code-with-quarkus</code>"

#. type: Content of: <div><div><div><h2>
#. mt: gemini
#: _includes/get-started-code-steps.html:50
msgid "Step <span class=\"step-no\">3</span>"
msgstr "ステップ <span class=\"step-no\">3</span>"

#. type: Content of: <div><div><div><h3>
#. mt: gemini
#: _includes/get-started-code-steps.html:53
msgid "Run the Getting Started Application"
msgstr "入門アプリケーションの実行"

#. type: Content of: <div><div><div><div><div><div><div><pre>
#. mt: gemini
#: _includes/get-started-code-steps.html:59
#, no-wrap
msgid "<code>quarkus dev</code>"
msgstr "<code>quarkus dev</code>"

#. type: Content of: <div><div><div><h4>
#. mt: gemini
#: _includes/get-started-code-steps.html:64
msgid "Boom! Your Quarkus app is now running at <code>localhost:8080</code>"
msgstr "Quarkus アプリは <code>localhost:8080</code> で実行中です。"

#. type: Content of: <div><div><div><h2>
#. mt: gemini
#: _includes/get-started-code-steps.html:67
msgid "Step <span class=\"step-no\">4</span>"
msgstr "ステップ <span class=\"step-no\">4</span>"

#. type: Content of: <div><div><div><h3>
#. mt: gemini
#: _includes/get-started-code-steps.html:70
msgid "Live Coding with Quarkus"
msgstr "Quarkus でのライブコーディング"

#. type: Content of: <div><div><div><p>
#. mt: gemini
#: _includes/get-started-code-steps.html:71
msgid "Quarkus makes it easy to change your code on the fly. Let's modify the <a href=\"http://localhost:8080/hello\">RESTful endpoint</a>"
msgstr "Quarkus を使用すると、コードをその場で簡単に変更できます。<a href=\"http://localhost:8080/hello\">RESTful エンドポイント</a>を変更してみましょう。"

#. type: Content of: <div><div><div><br><p>
#. mt: gemini
#: _includes/get-started-code-steps.html:73
msgid "Open <code>src/main/java/org/acme/GreetingResource.java</code> in a text editor or your <a href=\"https://quarkus.io/guides/ide-tooling\">favorite IDE</a> and change \"Hello from RESTEasy Reactive\" to \"Hola from RESTEasy Reactive\". Then refresh the browser and see the changes."
msgstr "テキストエディターまたは<a href=\"https://quarkus.io/guides/ide-tooling\">お気に入りの IDE</a> で <code>src/main/java/org/acme/GreetingResource.java</code> を開き、「Hello from RESTEasy Reactive」を「Hola from RESTEasy Reactive」に変更します。その後、ブラウザーを更新して変更を確認してください。"

#. type: Content of: <div><div><div><br><div><div><pre>
#. mt: gemini
#: _includes/get-started-code-steps.html:77
#, no-wrap
msgid ""
"<code>\n"
"@Path(\"/hello\")\n"
"public class GreetingResource {\n"
"\n"
"    @GET\n"
"    @Produces(MediaType.TEXT_PLAIN)\n"
"    public String hello() {\n"
"        return \"Hello RESTEasy\";\n"
"    }\n"
"}\n"
"</code>"
msgstr ""
"<code>\n"
"@Path(\"/hello\")\n"
"public class GreetingResource {\n"
"\n"
"    @GET\n"
"    @Produces(MediaType.TEXT_PLAIN)\n"
"    public String hello() {\n"
"        return \"Hello RESTEasy\";\n"
"    }\n"
"}\n"
"</code>"

#. type: Content of: <div><div><div><br><h4>
#. mt: gemini
#: _includes/get-started-code-steps.html:90
msgid "Cool stuff right? <a href=\"https://quarkus.io/guides/maven-tooling#dev-mode\">Learn more about Quarkus's dev mode</a>."
msgstr "素晴らしいでしょう？<a href=\"https://quarkus.io/guides/maven-tooling#dev-mode\">Quarkus の開発モードの詳細はこちら</a>。"
