#. type: Content of: <div><div><div><h2>
#: _includes/homepage-imperative_and_reactive-band.html:4
msgid "Unifies Imperative and Reactive"
msgstr "命令型とリアクティブ型の統一"

#. type: Content of: <div><div><div><p>
#: _includes/homepage-imperative_and_reactive-band.html:7
msgid "Combine both the familiar imperative code and the reactive style when developing applications.  <a href=\"/continuum\">Learn more</a>."
msgstr "<a href=\"/continuum\">詳しくはこちら</a>。"

#. type: Content of: <div><div><div><div><div><div>
#: _includes/homepage-imperative_and_reactive-band.html:13
msgid "Imperative"
msgstr "命令型"

#. type: Content of: <div><div><div><div><div><div><pre>
#: _includes/homepage-imperative_and_reactive-band.html:15
#, no-wrap
msgid ""
"<code>@Inject\n"
"SayService say;\n"
"\n"
"@GET\n"
"@Produces(MediaType.TEXT_PLAIN)\n"
"public String hello() {\n"
"    return say.hello();\n"
"}</code>"
msgstr ""
"<code>@Inject\n"
"SayService say;\n"
"\n"
"@GET\n"
"@Produces(MediaType.TEXT_PLAIN)\n"
"public String hello() {\n"
"    return say.hello();\n"
"}</code>"

#. type: Content of: <div><div><div><div><div><div>
#: _includes/homepage-imperative_and_reactive-band.html:26
msgid "Reactive"
msgstr "リアクティブ"

#. type: Content of: <div><div><div><div><div><div><pre>
#: _includes/homepage-imperative_and_reactive-band.html:28
#, no-wrap
msgid ""
"<code>@Channel(\"kafka\") Multi&lt;String&gt; events;\n"
"\n"
"@GET\n"
"@Produces(MediaType.SERVER_SENT_EVENTS)\n"
"public Multi&lt;String&gt; events() {\n"
"    return events;\n"
"}</code>"
msgstr ""
"<code>@Channel(\"kafka\") Multi&lt;String&gt; events;\n"
"\n"
"@GET\n"
"@Produces(MediaType.SERVER_SENT_EVENTS)\n"
