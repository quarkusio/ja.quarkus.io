#. type: Hash Value: jobs sync steps name
#: .github/workflows/sync-releases.yml:1
#, no-wrap
msgid "Commit and push"
msgstr ""

#. type: Hash Value: jobs sync steps run
#: .github/workflows/sync-releases.yml:1
#, no-wrap
msgid ""
"git config --local user.email \"action@github.com\"\n"
"git config --local user.name \"GitHub Action\"\n"
"git add _data/releases.yaml\n"
"if [ -n \"$(git status --porcelain)\" ]; then\n"
"  git commit -m \"Sync releases data\"\n"
"  git pull origin main --rebase\n"
"  git push origin main\n"
"fi\n"
msgstr ""

