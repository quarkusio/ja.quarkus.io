msgstr ""

#. type: Hash Value: jobs build steps run
#: .github/workflows/build.yml:1
#, no-wrap
msgid "bundle exec jekyll build --future --config _config.yml,_only_latest_guides_config.yml"
msgstr ""

#. type: Hash Value: jobs build steps name
#: .github/workflows/build.yml:1
#, no-wrap
msgid "Store PR id"
msgstr ""

#. type: Hash Value: jobs build steps run
#: .github/workflows/build.yml:1
#, no-wrap
msgid "echo ${{ github.event.number }} > ./_site/pr-id.txt"
msgstr ""

#. type: Hash Value: jobs build steps name
#: .github/workflows/build.yml:1
#, no-wrap
msgid "Reduce the size of the website to be compatible with surge"
msgstr ""

#. type: Hash Value: jobs build steps run
#: .github/workflows/build.yml:1
#, no-wrap
msgid ""
"find assets/images/posts/ -mindepth 1 -maxdepth 1 -type d -mtime +50 -exec rm -rf _site/{} \\;\n"
"find newsletter/ -mindepth 1 -maxdepth 1 -type d -mtime +50 -exec rm -rf _site/{} \\;\n"
"rm -rf _site/assets/stickers\n"
"rm -rf _site/assets/images/worldtour/2023\n"
"rm -rf _site/assets/images/worldtour/2024\n"
"rm -rf _site/assets/images/desktopwallpapers\n"
"rm -rf _site/assets/images/stickers\n"
msgstr ""

