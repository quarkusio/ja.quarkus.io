#. type: Hash Value: jobs deploy steps name
#: .github/workflows/deploy.yml:1
#, no-wrap
msgid "Sync gh-pages branch"
msgstr ""

#. type: Hash Value: jobs deploy steps run
#: .github/workflows/deploy.yml:1
#, no-wrap
msgid ""
"SITE_DIR=$(mktemp -d)\n"
"rsync -a ./${{ steps.detect.outputs.site_dir }}/ \"$SITE_DIR\"\n"
"git config --local user.email \"action@github.com\"\n"
"git config --local user.name \"GitHub Action\"\n"
"git fetch origin gh-pages:gh-pages\n"
"git checkout gh-pages\n"
"rsync -a --delete --exclude='.git' --exclude='.nojekyll' \"$SITE_DIR\"/ .\n"
"git add -A\n"
"git rm -rf --cached --ignore-unmatch ${{ steps.detect.outputs.site_dir }}\n"
"git commit --allow-empty -m \"deploy: ${{ github.sha }}\"\n"
"git push origin gh-pages\n"
msgstr ""

