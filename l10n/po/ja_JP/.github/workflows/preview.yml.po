#. type: Hash Value: jobs preview steps name
#: .github/workflows/preview.yml:1
#, no-wrap
msgid "Store PR id as variable"
msgstr ""

#. type: Hash Value: jobs preview steps run
#: .github/workflows/preview.yml:1
#, no-wrap
msgid ""
"pr=$(<pr-id.txt)\n"
"if ! [[ $pr =~ ^[0-9]+$ ]] ; then\n"
"  echo \"PR id extracted from pr-id.txt is not a number: $pr\"\n"
"  exit 1\n"
"fi\n"
"echo \"id=${pr}\" >> $GITHUB_OUTPUT\n"
"rm -f pr-id.txt\n"
msgstr ""

