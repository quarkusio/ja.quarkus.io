#: _versions/3.34/guides/aot.adoc
msgid "Then run the application with:"
msgstr ""

#. type: Title =
#: _versions/3.34/guides/aot.adoc
msgid "AOT-optimized JAR packaging"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/aot.adoc
msgid ""
"Quarkus provides a specialized `aot-jar` packaging type designed to work optimally with OpenJDK's AOT features.\n"
"This packaging type:"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/aot.adoc
msgid "Structures the application for optimal AOT class loading"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/aot.adoc
msgid "Delegates all class loading to the JDK's class loaders (required for AOT to work effectively as Leyden currently does not support custom class loaders)"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/aot.adoc
msgid "Caches frequently-accessed resources (like service loader files) to avoid classpath scanning at runtime"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/aot.adoc
msgid "It is not recommended to use the `aot-jar` packaging outside of the AOT use case, as the `fast-jar` packaging offers more optimizations that result in better performance compared to the `aot-jar` when Leyden's AOT cache is not used."
msgstr ""

