#. type: Title =
#: _versions/3.34/guides/aot.adoc
msgid "Requirements and limitations"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/aot.adoc
msgid "**JDK 24 or newer** is required for Leyden AOT features"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/aot.adoc
msgid "The AOT cache is **JDK version specific** - you must use the exact same JDK version at runtime as was used to generate the cache"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/aot.adoc
msgid "The feature is untested on Windows environments"
