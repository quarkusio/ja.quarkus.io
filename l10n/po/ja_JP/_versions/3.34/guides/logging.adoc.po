#. type: YAML Front Matter: title
#: _versions/3.34/guides/logging.adoc
msgid "Logging configuration"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/logging.adoc
msgid "Read about the use of logging API in {project-name}, configuring logging output, and using logging adapters to unify the output from other logging APIs."
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/logging.adoc
msgid "This document is part of the xref:observability.adoc[Observability in Quarkus reference guide] which features this and other observability related components."
