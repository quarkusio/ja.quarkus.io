msgid "Hibernate Search Elasticsearch"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/elasticsearch.adoc
msgid "Quarkus supports Hibernate Search with Elasticsearch via the `quarkus-hibernate-search-orm-elasticsearch` extension."
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/elasticsearch.adoc
