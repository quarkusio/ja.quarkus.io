msgstr ""

#. type: Plain text
#: _versions/3.34/guides/cli-tooling.adoc
msgid "`--concise` Display the name (artifactId) and description"
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/cli-tooling.adoc
msgid "`--full`    Display concise format and version/status-related columns."
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/cli-tooling.adoc
msgid "`--origins` Display concise information along with the Quarkus platform release origin of the extension."
msgstr ""

#. type: Plain text
#: _versions/3.34/guides/cli-tooling.adoc
msgid "`--support-scope` Display support scope associated with each extension (if any) for an offering configured in the registry client configuration."
msgstr ""

