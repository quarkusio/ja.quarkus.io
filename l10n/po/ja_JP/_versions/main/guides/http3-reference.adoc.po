msgstr ""

#. type: Title =
#: _versions/main/guides/http3-reference.adoc
msgid "Limitations"
msgstr ""

#. type: Plain text
#: _versions/main/guides/http3-reference.adoc
msgid "**Experimental** — This feature is under active development. APIs and behavior may change."
msgstr ""

#. type: Plain text
#: _versions/main/guides/http3-reference.adoc
msgid "**UDP in containers** — HTTP/3 uses UDP. If your application runs in a container (Docker, Kubernetes), ensure UDP port forwarding is configured for the HTTPS port. Some corporate firewalls may also block UDP traffic."
msgstr ""

#. type: Plain text
#: _versions/main/guides/http3-reference.adoc
msgid "**No WebSocket over HTTP/3** — WebSocket connections use HTTP/1.1 or HTTP/2. This is a Vert.x limitation, not specific to Quarkus."
msgstr ""

#. type: Plain text
#: _versions/main/guides/http3-reference.adoc
msgid "**Native image** — HTTP/3 requires a platform-specific native QUIC library (`netty-codec-native-quic`). The correct classifier for your platform must be on the classpath."
msgstr ""

