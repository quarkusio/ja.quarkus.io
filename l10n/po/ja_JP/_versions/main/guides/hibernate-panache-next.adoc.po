#: _versions/main/guides/hibernate-panache-next.adoc
msgid "`Session` (managed, blocking)"
msgstr "`Session` (マネージド、ブロッキング)"

#. type: Table
#: _versions/main/guides/hibernate-panache-next.adoc
msgid "`PanacheRepository<Entity>`"
msgstr "`PanacheRepository<Entity>`"

