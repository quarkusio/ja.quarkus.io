#. type: Title =
#: _versions/main/guides/native-transport-reference.adoc
msgid "Configuration reference"
msgstr ""

#. type: Plain text
#: _versions/main/guides/native-transport-reference.adoc
msgid ""
"Quarkus provides two configuration properties to control native transport behavior.\n"
"Both are **build-time properties** (fixed at build time), meaning they are resolved during the Quarkus augmentation phase.\n"
"They can be set in `application.properties` and overridden using Quarkus profiles (e.g., `%dev`, `%prod`), but cannot be changed at runtime via environment variables."
msgstr ""

#. type: Table
#: _versions/main/guides/native-transport-reference.adoc
msgid "Property"
msgstr ""

#. type: Table
#: _versions/main/guides/native-transport-reference.adoc
msgid "Default"
msgstr ""

#. type: Table
#: _versions/main/guides/native-transport-reference.adoc
msgid "Description"
msgstr ""

#. type: Table
#: _versions/main/guides/native-transport-reference.adoc
msgid "`quarkus.vertx.native-transport` icon:lock[title=Fixed at build time]"
msgstr ""

#. type: Table
#: _versions/main/guides/native-transport-reference.adoc
msgid "`disabled`"
msgstr ""

#. type: Table
#: _versions/main/guides/native-transport-reference.adoc
msgid "Controls whether and how strictly native transport should be used. Accepted values: `disabled` (do not use native transport), `if-available` (use native transport if available, fall back to Java NIO otherwise), `required` (require native transport, the build fails if the dependency is missing, the application fails to start if the native library cannot load)."
msgstr ""

#. type: Table
#: _versions/main/guides/native-transport-reference.adoc
msgid "`quarkus.vertx.native-transport-type` icon:lock[title=Fixed at build time]"
msgstr ""

#. type: Table
#: _versions/main/guides/native-transport-reference.adoc
msgid "`auto`"
msgstr ""

#. type: Table
#: _versions/main/guides/native-transport-reference.adoc
msgid "Select a specific transport: `auto` (let Vert.x choose), `epoll`, `kqueue`, or `io-uring`. Setting this to a value other than `auto` implicitly enables native transport (treated as at least `if-available`)."
msgstr ""

#. type: Title ==
#: _versions/main/guides/native-transport-reference.adoc
msgid "Property relationships"
msgstr ""

#. type: Plain text
#: _versions/main/guides/native-transport-reference.adoc
msgid "Setting `native-transport=disabled` disables native transport entirely."
msgstr ""

#. type: Plain text
#: _versions/main/guides/native-transport-reference.adoc
msgid "Setting `native-transport-type` to a specific value (e.g., `epoll`) implicitly enables native transport, even if `native-transport` is `disabled`."
msgstr ""

#. type: Plain text
#: _versions/main/guides/native-transport-reference.adoc
msgid "When `native-transport=required`, missing dependencies cause a build failure, and a transport that cannot load at runtime causes a startup failure."
msgstr ""

