msgid "Built-in"
msgstr "組み込み"

#: _versions/3.33/guides/logging.adoc
msgid "link:https://docs.oracle.com/en/java/javase/17/docs/api/java.logging/java/util/logging/package-summary.html[JDK `java.util.logging` (JUL)]"
msgstr "link:https://docs.oracle.com/en/java/javase/17/docs/api/java.logging/java/util/logging/package-summary.html[JDK `java.util.logging` (JUL)]"

#: _versions/3.33/guides/logging.adoc
